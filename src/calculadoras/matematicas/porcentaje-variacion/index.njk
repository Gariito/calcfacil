<div class="row-2">
  <div>
    <label>Valor inicial</label>
    <input type="number" id="vp-ini" placeholder="80" oninput="calcVP()">
  </div>
  <div>
    <label>Valor final</label>
    <input type="number" id="vp-fin" placeholder="100" oninput="calcVP()">
  </div>
</div>

<div class="result-box" id="vp-res">Introduce los dos valores</div>

<script>
function calcVP() {
  const ini = parseFloat(document.getElementById('vp-ini').value);
  const fin = parseFloat(document.getElementById('vp-fin').value);
  if (!ini || isNaN(fin)) return;
  const variacion = (fin - ini) / Math.abs(ini) * 100;
  const dif = fin - ini;
  const signo = variacion >= 0 ? '▲' : '▼';
  const color = variacion >= 0 ? '#22C55E' : '#EF4444';
  document.getElementById('vp-res').innerHTML =
    `<span style="color:${color}">${signo} ${Math.abs(variacion).toFixed(2)}%</span>
    <small>Diferencia: ${dif >= 0 ? '+' : ''}${dif.toFixed(4)} · De ${ini} a ${fin}</small>`;
}
</script