<label>Tipo de proporción</label>
<select id="r3-tipo" onchange="calcR3()">
  <option value="directa">Directa (si A sube, B sube)</option>
  <option value="inversa">Inversa (si A sube, B baja)</option>
</select>

<div style="background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:1rem;margin-bottom:1rem;font-size:0.85rem;color:var(--muted)">
  Si <b id="r3-a-label">A</b> = <input type="number" id="r3-a" placeholder="10" oninput="calcR3()" style="width:80px;display:inline;margin:0 0.25rem">
  entonces <b id="r3-b-label">B</b> = <input type="number" id="r3-b" placeholder="25" oninput="calcR3()" style="width:80px;display:inline;margin:0 0.25rem"><br><br>
  Si <b>A</b> = <input type="number" id="r3-c" placeholder="6" oninput="calcR3()" style="width:80px;display:inline;margin:0 0.25rem">
  entonces <b>B</b> = <b id="r3-x" style="color:var(--accent)">?</b>
</div>

<div class="result-box" id="r3-res">Introduce los tres valores conocidos</div>

<script>
function calcR3() {
  const a = parseFloat(document.getElementById('r3-a').value);
  const b = parseFloat(document.getElementById('r3-b').value);
  const c = parseFloat(document.getElementById('r3-c').value);
  const tipo = document.getElementById('r3-tipo').value;
  if (isNaN(a) || isNaN(b) || isNaN(c) || a === 0) return;
  const x = tipo === 'directa' ? (b * c) / a : (a * b) / c;
  document.getElementById('r3-x').textContent = parseFloat(x.toFixed(6)).toLocaleString('es-ES', {maximumFractionDigits:4});
  document.getElementById('r3-res').innerHTML =
    `X = ${parseFloat(x.toFixed(8)).toLocaleString('es-ES', {maximumFractionDigits:6})}<small>Proporción ${tipo}: ${a} → ${b} · ${c} → ${x.toFixed(4)}</small>`;
}
</script>