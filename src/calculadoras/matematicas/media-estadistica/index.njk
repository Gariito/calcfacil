<label>Introduce los números separados por comas o espacios</label>
<input type="text" id="est-datos" placeholder="4, 7, 2, 9, 4, 1, 7, 4" oninput="calcEst()">

<div class="result-box" id="est-res">Introduce una serie de números</div>

<script>
function calcEst() {
  const raw = document.getElementById('est-datos').value;
  const nums = raw.split(/[\s,;]+/).map(Number).filter(n => !isNaN(n) && n !== '');
  if (nums.length < 2) return;
  const sorted = [...nums].sort((a, b) => a - b);
  const n = nums.length;
  const media = nums.reduce((a, b) => a + b, 0) / n;
  const mediana = n % 2 === 0 ? (sorted[n/2-1] + sorted[n/2]) / 2 : sorted[Math.floor(n/2)];
  const freq = {};
  nums.forEach(v => freq[v] = (freq[v] || 0) + 1);
  const maxFreq = Math.max(...Object.values(freq));
  const moda = Object.keys(freq).filter(k => freq[k] === maxFreq).join(', ');
  const rango = sorted[n-1] - sorted[0];
  const varianza = nums.reduce((a, b) => a + Math.pow(b - media, 2), 0) / n;
  const desv = Math.sqrt(varianza);
  document.getElementById('est-res').innerHTML =
    `Media: ${media.toFixed(4)}<small>
    Mediana: ${mediana} · 
    Moda: ${moda} (${maxFreq}×) · 
    Rango: ${rango} · 
    Desv. típica: ${desv.toFixed(4)} · 
    N: ${n} datos</small>`;
}
</script>