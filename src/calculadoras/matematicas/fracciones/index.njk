<label>Operación</label>
<select id="frac-op" onchange="calcFrac()">
  <option value="suma">Suma (a/b + c/d)</option>
  <option value="resta">Resta (a/b − c/d)</option>
  <option value="mult">Multiplicación (a/b × c/d)</option>
  <option value="div">División (a/b ÷ c/d)</option>
</select>

<div style="display:grid;grid-template-columns:1fr auto 1fr;gap:1rem;align-items:center;margin-bottom:1rem">
  <div>
    <label>Numerador 1</label>
    <input type="number" id="frac-a" placeholder="1" oninput="calcFrac()">
    <div style="border-top:2px solid var(--text);margin:0.25rem 0"></div>
    <label>Denominador 1</label>
    <input type="number" id="frac-b" placeholder="3" oninput="calcFrac()">
  </div>
  <div style="font-size:1.5rem;font-weight:700;text-align:center;padding-top:1rem" id="frac-simbolo">+</div>
  <div>
    <label>Numerador 2</label>
    <input type="number" id="frac-c" placeholder="1" oninput="calcFrac()">
    <div style="border-top:2px solid var(--text);margin:0.25rem 0"></div>
    <label>Denominador 2</label>
    <input type="number" id="frac-d" placeholder="4" oninput="calcFrac()">
  </div>
</div>

<div class="result-box" id="frac-res">Introduce los valores de las fracciones</div>

<script>
function gcdF(a, b) { return b === 0 ? Math.abs(a) : gcdF(b, a % b); }

document.getElementById('frac-op').addEventListener('change', function() {
  const simbolos = { suma:'+', resta:'−', mult:'×', div:'÷' };
  document.getElementById('frac-simbolo').textContent = simbolos[this.value];
  calcFrac();
});

function calcFrac() {
  const a = parseInt(document.getElementById('frac-a').value);
  const b = parseInt(document.getElementById('frac-b').value);
  const c = parseInt(document.getElementById('frac-c').value);
  const d = parseInt(document.getElementById('frac-d').value);
  const op = document.getElementById('frac-op').value;
  if (isNaN(a)||isNaN(b)||isNaN(c)||isNaN(d)||b===0||d===0) return;

  let rn, rd;
  if (op === 'suma') { rn = a*d + c*b; rd = b*d; }
  else if (op === 'resta') { rn = a*d - c*b; rd = b*d; }
  else if (op === 'mult') { rn = a*c; rd = b*d; }
  else { rn = a*d; rd = b*c; }

  if (rd === 0) { document.getElementById('frac-res').textContent = 'División por cero'; return; }
  if (rd < 0) { rn = -rn; rd = -rd; }

  const g = gcdF(Math.abs(rn), Math.abs(rd));
  const sn = rn/g, sd = rd/g;
  const decimal = rn/rd;

  document.getElementById('frac-res').innerHTML = sd === 1
    ? `${sn}<small>${a}/${b} ${op==='suma'?'+':op==='resta'?'−':op==='mult'?'×':'÷'} ${c}/${d} = ${sn}</small>`
    : `${sn}/${sd}<small>Fracción simplificada · Decimal: ${decimal.toFixed(6).replace(/\.?0+$/, '')}</small>`;
}
</script>