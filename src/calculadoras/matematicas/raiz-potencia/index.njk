<label>Número</label>
<input type="number" id="rp-num" placeholder="25" oninput="calcRP()">

<label>Operación</label>
<select id="rp-op" onchange="calcRP()">
  <option value="sqrt">Raíz cuadrada (√x)</option>
  <option value="cbrt">Raíz cúbica (∛x)</option>
  <option value="sq">Al cuadrado (x²)</option>
  <option value="cb">Al cubo (x³)</option>
  <option value="pow">Potencia personalizada (xⁿ)</option>
</select>

<div id="rp-exp-wrap" style="display:none">
  <label>Exponente (n)</label>
  <input type="number" id="rp-exp" placeholder="4" oninput="calcRP()">
</div>

<div class="result-box" id="rp-res">Introduce un número</div>

<script>
function calcRP() {
  const n = parseFloat(document.getElementById('rp-num').value);
  const op = document.getElementById('rp-op').value;
  document.getElementById('rp-exp-wrap').style.display = op === 'pow' ? 'block' : 'none';
  if (isNaN(n)) return;
  let r, label;
  if (op === 'sqrt') { r = Math.sqrt(n); label = `√${n}`; }
  else if (op === 'cbrt') { r = Math.cbrt(n); label = `∛${n}`; }
  else if (op === 'sq') { r = n * n; label = `${n}²`; }
  else if (op === 'cb') { r = n * n * n; label = `${n}³`; }
  else {
    const exp = parseFloat(document.getElementById('rp-exp').value);
    if (isNaN(exp)) return;
    r = Math.pow(n, exp); label = `${n}^${exp}`;
  }
  document.getElementById('rp-res').innerHTML =
    `${label} = ${parseFloat(r.toFixed(10)).toLocaleString('es-ES', {maximumFractionDigits:8})}`;
}
</script>