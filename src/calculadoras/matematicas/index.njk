<div class="cat-page">
  <div class="container">
    <div class="cat-header">
      <h1>🔢 Calculadoras matemáticas</h1>
      <p>Operaciones matemáticas frecuentes, resueltas al instante.</p>
    </div>

    <div class="search-wrap">
      <span class="search-icon">🔍</span>
      <input type="text" class="search-input" id="cat-search"
        placeholder="Buscar... raíz, fracciones, primos, MCD..."
        oninput="searchCat(this.value)" autocomplete="off">
      <div class="search-count" id="cat-count"></div>
    </div>

    <div class="search-empty" id="cat-empty">
      <div class="empty-icon">🔍</div>
      <p>No se encontraron calculadoras para "<span id="cat-empty-term"></span>"</p>
    </div>

    <div class="calc-cards" id="cat-grid">
      <a class="calc-card-link" href="/calculadoras/matematicas/raiz-potencia/">
        <span class="icon">√</span>
        <div><h2>Raíz y potencias</h2><p>Calcula raíces cuadradas, cúbicas y potencias de cualquier número.</p></div>
      </a>
      <a class="calc-card-link" href="/calculadoras/matematicas/fracciones/">
        <span class="icon">½</span>
        <div><h2>Calculadora de fracciones</h2><p>Suma, resta, multiplica y divide fracciones con simplificación automática.</p></div>
      </a>
      <a class="calc-card-link" href="/calculadoras/matematicas/mcd-mcm/">
        <span class="icon">🔢</span>
        <div><h2>MCD y MCM</h2><p>Calcula el máximo común divisor y el mínimo común múltiplo.</p></div>
      </a>
      <a class="calc-card-link" href="/calculadoras/matematicas/numeros-primos/">
        <span class="icon">🔢</span>
        <div><h2>Números primos</h2><p>Comprueba si un número es primo y obtén su factorización prima.</p></div>
      </a>
      <a class="calc-card-link" href="/calculadoras/matematicas/regla-de-tres/">
        <span class="icon">📏</span>
        <div><h2>Regla de tres</h2><p>Resuelve proporciones directas e inversas al instante.</p></div>
      </a>
      <a class="calc-card-link" href="/calculadoras/matematicas/media-estadistica/">
        <span class="icon">📊</span>
        <div><h2>Media, mediana y moda</h2><p>Calcula las medidas de tendencia central de una serie de datos.</p></div>
      </a>
      <a class="calc-card-link" href="/calculadoras/matematicas/porcentaje-variacion/">
        <span class="icon">📈</span>
        <div><h2>Variación porcentual</h2><p>Calcula el porcentaje de aumento o disminución entre dos valores.</p></div>
      </a>
    </div>
  </div>
</div>

<script>
function searchCat(q) {
  const term = q.toLowerCase().trim();
  const cards = document.querySelectorAll('#cat-grid .calc-card-link');
  const empty = document.getElementById('cat-empty');
  const count = document.getElementById('cat-count');
  let visible = 0;
  cards.forEach(card => {
    const text = card.textContent.toLowerCase();
    if (!term || text.includes(term)) { card.classList.remove('hidden'); visible++; }
    else card.classList.add('hidden');
  });
  if (term) {
    count.textContent = visible + ' calculadora' + (visible !== 1 ? 's' : '') + ' encontrada' + (visible !== 1 ? 's' : '');
    document.getElementById('cat-empty-term').textContent = q;
    empty.style.display = visible === 0 ? 'block' : 'none';
  } else { count.textContent = ''; empty.style.display = 'none'; }
}
</script>