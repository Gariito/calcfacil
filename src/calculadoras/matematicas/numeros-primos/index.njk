<label>Número a comprobar</label>
<input type="number" id="pr-num" placeholder="97" oninput="calcPrimo()">

<div class="result-box" id="pr-res">Introduce un número</div>

<script>
function esPrimo(n) {
  if (n < 2) return false;
  if (n === 2) return true;
  if (n % 2 === 0) return false;
  for (let i = 3; i <= Math.sqrt(n); i += 2) {
    if (n % i === 0) return false;
  }
  return true;
}

function factorizar(n) {
  const factores = [];
  let d = 2;
  while (d * d <= n) {
    while (n % d === 0) { factores.push(d); n = Math.floor(n / d); }
    d++;
  }
  if (n > 1) factores.push(n);
  return factores;
}

function calcPrimo() {
  const n = parseInt(document.getElementById('pr-num').value);
  if (isNaN(n) || n < 1) return;

  const primo = esPrimo(n);
  const factores = factorizar(n);

  // Siguiente y anterior primo
  let sig = n + 1;
  while (!esPrimo(sig)) sig++;
  let ant = n - 1;
  while (ant > 1 && !esPrimo(ant)) ant--;

  if (primo) {
    document.getElementById('pr-res').innerHTML =
      `${n} ES un número primo ✓
      <small>Anterior primo: ${ant > 1 ? ant : '—'} · Siguiente primo: ${sig}</small>`;
  } else {
    document.getElementById('pr-res').innerHTML =
      `${n} NO es primo
      <small>Factores primos: ${factores.join(' × ')} · Anterior primo: ${ant > 1 ? ant : '—'} · Siguiente primo: ${sig}</small>`;
  }
}
</script>