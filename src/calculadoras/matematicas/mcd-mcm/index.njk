<label>Números (separados por comas)</label>
<input type="text" id="mcd-nums" placeholder="12, 18, 24" oninput="calcMCD()">

<div class="result-box" id="mcd-res">Introduce dos o más números</div>

<script>
function gcd(a, b) { return b === 0 ? a : gcd(b, a % b); }
function lcm(a, b) { return (a * b) / gcd(a, b); }

function calcMCD() {
  const raw = document.getElementById('mcd-nums').value;
  const nums = raw.split(/[\s,;]+/).map(Number).filter(n => Number.isInteger(n) && n > 0);
  if (nums.length < 2) return;

  const mcdVal = nums.reduce(gcd);
  const mcmVal = nums.reduce(lcm);

  const divisoresMCD = [];
  for (let i = 1; i <= mcdVal; i++) {
    if (mcdVal % i === 0) divisoresMCD.push(i);
  }

  document.getElementById('mcd-res').innerHTML =
    `MCD: ${mcdVal} · MCM: ${mcmVal.toLocaleString('es-ES')}
    <small>Divisores del MCD: ${divisoresMCD.join(', ')}</small>`;
}
</script>