---
layout: base.njk
title: Calculadoras de cocina gratuitas
description: Calculadoras de cocina gratuitas. Raciones, temperatura de horno y conversión de ingredientes.
keywords: calculadora cocina, raciones receta, temperatura horno, tazas a gramos
---

<div class="cat-page">
  <div class="container">
    <div class="cat-header">
      <h1>🍳 Calculadoras de cocina</h1>
      <p>Herramientas para cocinar con precisión y sin complicaciones.</p>
    </div>

    <div class="search-wrap">
      <span class="search-icon">🔍</span>
      <input type="text" class="search-input" id="cat-search"
        placeholder="Buscar... raciones, horno, gramos, tazas..."
        oninput="searchCat(this.value)" autocomplete="off">
      <div class="search-count" id="cat-count"></div>
    </div>

    <div class="search-empty" id="cat-empty">
      <div class="empty-icon">🔍</div>
      <p>No se encontraron calculadoras para "<span id="cat-empty-term"></span>"</p>
    </div>

    <div class="calc-cards" id="cat-grid">
      <a class="calc-card-link" href="/calculadoras/cocina/raciones/">
        <span class="icon">🍽️</span>
        <div><h2>Ajuste de raciones</h2><p>Adapta cualquier receta al número de comensales que necesites.</p></div>
      </a>
      <a class="calc-card-link" href="/calculadoras/cocina/temperatura-horno/">
        <span class="icon">🌡️</span>
        <div><h2>Temperatura de horno</h2><p>Convierte entre grados Celsius, Fahrenheit y termostato de gas.</p></div>
      </a>
      <a class="calc-card-link" href="/calculadoras/cocina/conversion-ingredientes/">
        <span class="icon">⚖️</span>
        <div><h2>Conversión de ingredientes</h2><p>Convierte tazas, cucharadas y onzas a gramos para los ingredientes más comunes.</p></div>
      </a>
    </div>
  </div>
</div>

<script>
function searchCat(q) {
  const term = q.toLowerCase().trim();
  const cards = document.querySelectorAll('#cat-grid .calc-card-link');
  const empty = document.getElementById('cat-empty');
  const count = document.getElementById('cat-count');
  let visible = 0;
  cards.forEach(card => {
    const text = card.textContent.toLowerCase();
    if (!term || text.includes(term)) { card.classList.remove('hidden'); visible++; }
    else card.classList.add('hidden');
  });
  if (term) {
    count.textContent = visible + ' calculadora' + (visible !== 1 ? 's' : '') + ' encontrada' + (visible !== 1 ? 's' : '');
    document.getElementById('cat-empty-term').textContent = q;
    empty.style.display = visible === 0 ? 'block' : 'none';
  } else { count.textContent = ''; empty.style.display = 'none'; }
}
</script>