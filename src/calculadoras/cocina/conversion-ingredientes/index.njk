---

<label>Ingrediente</label>
<select id="ing-tipo" onchange="calcIng()">
  <option value="125">Harina de trigo (todo uso)</option>
  <option value="200">Azúcar blanco</option>
  <option value="220">Azúcar moreno (compacto)</option>
  <option value="100">Azúcar glass</option>
  <option value="230">Sal</option>
  <option value="240">Agua / leche</option>
  <option value="227">Mantequilla</option>
  <option value="85">Cacao en polvo</option>
  <option value="190">Arroz</option>
  <option value="185">Avena</option>
  <option value="150">Nueces picadas</option>
  <option value="170">Miel</option>
</select>

<div class="row-2">
  <div>
    <label>Cantidad</label>
    <input type="number" id="ing-cant" placeholder="1" oninput="calcIng()">
  </div>
  <div>
    <label>Unidad</label>
    <select id="ing-unidad" onchange="calcIng()">
      <option value="1">Taza (240 ml)</option>
      <option value="0.0625">Cucharada (15 ml)</option>
      <option value="0.020833">Cucharadita (5 ml)</option>
      <option value="0.5">Media taza</option>
      <option value="0.25">¼ taza</option>
    </select>
  </div>
</div>

<div class="result-box" id="ing-res">Introduce la cantidad</div>

<script>
function calcIng() {
  const grPorTaza = parseFloat(document.getElementById('ing-tipo').value);
  const cant = parseFloat(document.getElementById('ing-cant').value);
  const factor = parseFloat(document.getElementById('ing-unidad').value);
  if (!cant) return;
  const gramos = grPorTaza * cant * factor;
  document.getElementById('ing-res').innerHTML =
    `${gramos.toFixed(1)} g<small>${cant} ${document.getElementById('ing-unidad').options[document.getElementById('ing-unidad').selectedIndex].text} = ${gramos.toFixed(1)} gramos</small>`;
}
</script>