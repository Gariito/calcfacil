<div class="row-2">
  <div>
    <label>Raciones originales</label>
    <input type="number" id="rac-orig" placeholder="4" oninput="calcRaciones()">
  </div>
  <div>
    <label>Raciones que necesitas</label>
    <input type="number" id="rac-nueva" placeholder="6" oninput="calcRaciones()">
  </div>
</div>

<label>Cantidad de un ingrediente (opcional)</label>
<input type="number" id="rac-cant" placeholder="200" oninput="calcRaciones()">
<label>Unidad</label>
<select id="rac-unidad" onchange="calcRaciones()">
  <option>g</option><option>kg</option><option>ml</option>
  <option>L</option><option>tazas</option><option>cucharadas</option>
  <option>cucharaditas</option><option>unidades</option>
</select>

<div class="result-box" id="rac-res">Introduce las raciones</div>

<script>
function calcRaciones() {
  const orig = parseFloat(document.getElementById('rac-orig').value);
  const nueva = parseFloat(document.getElementById('rac-nueva').value);
  const cant = parseFloat(document.getElementById('rac-cant').value);
  const unidad = document.getElementById('rac-unidad').value;
  if (!orig || !nueva) return;
  const factor = nueva / orig;
  let html = `Factor: ×${factor.toFixed(3)}<small>Multiplica cada ingrediente por ${factor.toFixed(3)}`;
  if (cant) html += ` · ${cant} ${unidad} → ${(cant * factor).toFixed(1)} ${unidad}`;
  html += '</small>';
  document.getElementById('rac-res').innerHTML = html;
}
</script>