<label>Temperatura y escala de origen</label>
<div class="row-2">
  <div>
    <label>Valor</label>
    <input type="number" id="hor-val" placeholder="180" oninput="calcHorno()">
  </div>
  <div>
    <label>De</label>
    <select id="hor-from" onchange="calcHorno()">
      <option value="C">Celsius (°C)</option>
      <option value="F">Fahrenheit (°F)</option>
      <option value="G">Termostato gas</option>
    </select>
  </div>
</div>

<div class="result-box" id="hor-res">Introduce una temperatura</div>

<script>
function calcHorno() {
  const v = parseFloat(document.getElementById('hor-val').value);
  const f = document.getElementById('hor-from').value;
  if (isNaN(v)) return;
  let c;
  if (f === 'C') c = v;
  else if (f === 'F') c = (v - 32) * 5 / 9;
  else c = v * 25 + 121;
  const fahr = c * 9 / 5 + 32;
  const gas = Math.round((c - 121) / 25);
  document.getElementById('hor-res').innerHTML =
    `${c.toFixed(0)}°C · ${fahr.toFixed(0)}°F · Gas ${Math.max(1,Math.min(9,gas))}<small>Horno ${c < 150 ? 'muy suave' : c < 170 ? 'suave' : c < 190 ? 'medio' : c < 220 ? 'fuerte' : 'muy fuerte'}</small>`;
}
</script>