<label>Total de la cuenta (€)</label>
<input type="number" id="prop-total" placeholder="45.00" oninput="calcPropina()">

<label>Propina (%)</label>
<div style="display:flex;align-items:center;gap:1rem;margin-bottom:1rem">
  <input type="range" min="0" max="30" value="10" id="prop-pct"
    oninput="document.getElementById('prop-pct-val').textContent=this.value+'%'; calcPropina()"
    style="flex:1;margin-bottom:0">
  <span id="prop-pct-val" style="font-weight:600;min-width:40px;font-size:1.1rem">10%</span>
</div>

