<label>Modo</label>
<select id="t-modo" onchange="calcTiempo()">
  <option value="sumar">Sumar duraciones</option>
  <option value="restar">Restar duraciones</option>
  <option value="diferencia">Diferencia entre horas</option>
</select>

<div id="t-duraciones">
  <div class="row-2">
    <div><label>Horas (1)</label><input type="number" id="t-h1" placeholder="1" oninput="calcTiempo()"></div>
    <div><label>Minutos (1)</label><input type="number" id="t-m1" placeholder="45" oninput="calcTiempo()"></div>
  </div>
  <div class="row-2">
    <div><label>Horas (2)</label><input type="number" id="t-h2" placeholder="2" oninput="calcTiempo()"></div>
    <div><label>Minutos (2)</label><input type="number" id="t-m2" placeholder="30" oninput="calcTiempo()"></div>
  </div>
</div>

<div id="t-horas" style="display:none">
  <div class="row-2">
    <div>
      <label>Hora de inicio</label>
      <input type="time" id="t-ini" oninput="calcTiempo()" style="width:100%;padding:0.65rem 0.9rem;border:1px solid var(--border);border-radius:8px;font-size:1rem;background:var(--bg);margin-bottom:1rem">
    </div>
    <div>
      <label>Hora de fin</label>
      <input type="time" id="t-fin" oninput="calcTiempo()" style="width:100%;padding:0.65rem 0.9rem;border:1px solid var(--border);border-radius:8px;font-size:1rem;background:var(--bg);margin-bottom:1rem">
    </div>
  </div>
</div>


<div class="result-box" id="t-res">Introduce los tiempos</div>

<div style="margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--border)">
<h2 style="font-family:var(--font-display);font-size:1.2rem;font-weight:700;margin-bottom:1rem">Usos habituales de la calculadora de tiempo</h2>
<p style="color:var(--muted);font-size:0.9rem;line-height:1.8;margin-bottom:0.75rem"><strong>Cálculo de jornada laboral:</strong>Suma los turnos parciales de mañana y tarde para comprobar el cumplimiento de las horas semanales estipuladas por contrato.</p>
<p style="color:var(--muted);font-size:0.9rem;line-height:1.8;margin-bottom:0.75rem"><strong>Registro de actividades en proyectos:</strong>Suma los bloques de tiempo dedicados a distintas tareas informáticas, de diseño o consultoría para la facturación a clientes.</p>
<p style="color:var(--muted);font-size:0.9rem;line-height:1.8;margin-bottom:0.75rem"><strong>Control de tiempos deportivos:</strong>Acumula marcas de tiempo en tandas de carrera, ciclismo o natación para conocer la duración global del entrenamiento.</p>
<p style="color:var(--muted);font-size:0.9rem;line-height:1.8;margin-bottom:0.75rem"><strong>Edición de audio y vídeo:</strong>Suma la duración de diferentes clips, canciones o escenas para calcular el tiempo total de un proyecto audiovisual o podcast antes de exportarlo.</p>
<p style="color:var(--muted);font-size:0.9rem;line-height:1.8;margin-bottom:0.75rem"><strong>Planificación de viajes y vuelos:</strong>Suma la duración de varios trayectos, escalas y tiempos de espera en transbordos para calcular las horas totales de un itinerario de viaje.</p>

</div>

<div style="margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--border)">
<h2 style="font-family:var(--font-display);font-size:1.2rem;font-weight:700;margin-bottom:1rem">Ejemplo práctico: Sumar 2 horas y 45 minutos + 1 hora y 35 minutos</h2>
<p style="color:var(--muted);font-size:0.9rem;line-height:1.8;margin-bottom:0.75rem"><strong>Suma de minutos:</strong>45 + 35 = 80 minutos</p>
<p style="color:var(--muted);font-size:0.9rem;line-height:1.8;margin-bottom:0.75rem"><strong>Ajuste sexagesimal:</strong>Como 80 es mayor que 60, dividimos entre 60. Obtenemos <code>1 hora extra</code> y restan <code>20 minutos</code> (<code>80 - 60 = 20</code>).</p>
<p style="color:var(--muted);font-size:0.9rem;line-height:1.8;margin-bottom:0.75rem"><strong>Suma de horas:</strong>2 + 1 + 1 (hora sobrante) = 4 horas</p>
<p style="color:var(--muted);font-size:0.9rem;line-height:1.8;margin-bottom:0.75rem"><strong>Resultado definitivo:</strong>4 horas y 20 minutos</p>

</div>

<script>
document.getElementById('t-modo').addEventListener('change', function() {
  const m = this.value;
  document.getElementById('t-duraciones').style.display = m==='diferencia'?'none':'block';
  document.getElementById('t-horas').style.display = m==='diferencia'?'block':'none';
  calcTiempo();
});

function calcTiempo() {
  const modo = document.getElementById('t-modo').value;
  if (modo === 'diferencia') {
    const ini = document.getElementById('t-ini').value;
    const fin = document.getElementById('t-fin').value;
    if (!ini || !fin) return;
    const [h1,m1] = ini.split(':').map(Number);
    const [h2,m2] = fin.split(':').map(Number);
    let diff = (h2*60+m2) - (h1*60+m1);
    if (diff < 0) diff += 1440;
    const h = Math.floor(diff/60), m = diff%60;
    document.getElementById('t-res').innerHTML =
      `${h}h ${m}min<small>${diff} minutos en total</small>`;
  } else {
    const h1 = parseInt(document.getElementById('t-h1').value)||0;
    const m1 = parseInt(document.getElementById('t-m1').value)||0;
    const h2 = parseInt(document.getElementById('t-h2').value)||0;
    const m2 = parseInt(document.getElementById('t-m2').value)||0;
    let total = modo==='sumar' ? (h1*60+m1)+(h2*60+m2) : (h1*60+m1)-(h2*60+m2);
    const neg = total < 0;
    total = Math.abs(total);
    const h = Math.floor(total/60), m = total%60;
    document.getElementById('t-res').innerHTML =
      `${neg?'-':''}${h}h ${m}min<small>${neg?'-':''}${total} minutos en total</small>`;
  }
}
</script>