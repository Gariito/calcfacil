<label>Longitud de la contraseña</label>
<div style="display:flex;align-items:center;gap:1rem;margin-bottom:1rem">
  <input type="range" min="6" max="32" value="16" id="pw-len"
    oninput="document.getElementById('pw-len-val').textContent=this.value; genPW()"
    style="flex:1;margin-bottom:0">
  <span id="pw-len-val" style="font-weight:600;min-width:30px;font-size:1.1rem">16</span>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;margin-bottom:1rem">
  <label style="display:flex;align-items:center;gap:0.5rem;text-transform:none;letter-spacing:0;font-size:0.9rem">
    <input type="checkbox" id="pw-may" checked onchange="genPW()"> Mayúsculas (A-Z)
  </label>
  <label style="display:flex;align-items:center;gap:0.5rem;text-transform:none;letter-spacing:0;font-size:0.9rem">
    <input type="checkbox" id="pw-min" checked onchange="genPW()"> Minúsculas (a-z)
  </label>
  <label style="display:flex;align-items:center;gap:0.5rem;text-transform:none;letter-spacing:0;font-size:0.9rem">
    <input type="checkbox" id="pw-num" checked onchange="genPW()"> Números (0-9)
  </label>
  <label style="display:flex;align-items:center;gap:0.5rem;text-transform:none;letter-spacing:0;font-size:0.9rem">
    <input type="checkbox" id="pw-sim" checked onchange="genPW()"> Símbolos (!@#$)
  </label>
</div>

<div class="result-box" id="pw-res" style="font-family:monospace;font-size:1rem;letter-spacing:0.05em;word-break:break-all">
  Pulsa generar
</div>

<button onclick="genPW()" style="width:100%;margin-top:0.75rem;padding:0.75rem;background:var(--accent);color:#fff;border:none;border-radius:8px;font-size:1rem;font-family:var(--font-body);cursor:pointer;font-weight:500">
  🔄 Generar contraseña
</button>
<button onclick="copyPW()" style="width:100%;margin-top:0.5rem;padding:0.75rem;background:var(--bg);color:var(--text);border:1px solid var(--border);border-radius:8px;font-size:1rem;font-family:var(--font-body);cursor:pointer;font-weight:500">
  📋 Copiar
</button>

<script>
function genPW() {
  const len = parseInt(document.getElementById('pw-len').value);
  let chars = '';
  if (document.getElementById('pw-may').checked) chars += 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
  if (document.getElementById('pw-min').checked) chars += 'abcdefghijklmnopqrstuvwxyz';
  if (document.getElementById('pw-num').checked) chars += '0123456789';
  if (document.getElementById('pw-sim').checked) chars += '!@#$%^&*()-_=+[]{}|;:,.<>?';
  if (!chars) { document.getElementById('pw-res').textContent = 'Selecciona al menos un tipo de carácter'; return; }
  const arr = new Uint32Array(len);
  crypto.getRandomValues(arr);
  const pw = Array.from(arr).map(v => chars[v % chars.length]).join('');
  const fuerza = len < 8 ? 'Débil' : len < 12 ? 'Moderada' : len < 16 ? 'Fuerte' : 'Muy fuerte';
  document.getElementById('pw-res').innerHTML =
    `${pw}<small style="font-family:var(--font-body)">Seguridad: ${fuerza} · ${len} caracteres</small>`;
}
function copyPW() {
  const txt = document.getElementById('pw-res').firstChild?.textContent?.trim();
  if (!txt || txt === 'Pulsa generar') return;
  navigator.clipboard.writeText(txt).then(() => {
    const btn = event.target;
    btn.textContent = '✅ Copiado';
    setTimeout(() => btn.textContent = '📋 Copiar', 2000);
  });
}
genPW();
</script>