<div class="row-2">
  <div>
    <label>Fecha de inicio</label>
    <input type="date" id="df-inicio" oninput="calcDias()" style="width:100%;padding:0.65rem 0.9rem;border:1px solid var(--border);border-radius:8px;font-size:1rem;background:var(--bg);margin-bottom:1rem">
  </div>
  <div>
    <label>Fecha de fin</label>
    <input type="date" id="df-fin" oninput="calcDias()" style="width:100%;padding:0.65rem 0.9rem;border:1px solid var(--border);border-radius:8px;font-size:1rem;background:var(--bg);margin-bottom:1rem">
  </div>
</div>

<label>¿Incluir solo días laborables?</label>
<select id="df-laborables" onchange="calcDias()">
  <option value="no">No, todos los días</option>
  <option value="si">Sí, solo días laborables (lun-vie)</option>
</select>

<div class="result-box" id="df-res">Introduce las dos fechas</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const hoy = new Date().toISOString().split('T')[0];
  document.getElementById('df-inicio').value = hoy;
});

function calcDias() {
  const ini = document.getElementById('df-inicio').value;
  const fin = document.getElementById('df-fin').value;
  const lab = document.getElementById('df-laborables').value;
  if (!ini || !fin) return;

  const d1 = new Date(ini), d2 = new Date(fin);
  const diff = Math.round((d2 - d1) / 86400000);
  const label = diff < 0 ? 'La fecha de fin es anterior a la de inicio' : null;
  if (label) { document.getElementById('df-res').textContent = label; return; }

  let laborables = 0;
  if (lab === 'si') {
    let cur = new Date(d1);
    while (cur < d2) {
      const dow = cur.getDay();
      if (dow !== 0 && dow !== 6) laborables++;
      cur.setDate(cur.getDate() + 1);
    }
  }

  const semanas = Math.floor(diff / 7);
  const diasResto = diff % 7;
  const meses = Math.floor(diff / 30.44);

  document.getElementById('df-res').innerHTML =
    `${diff} días
    <small>${semanas} semanas y ${diasResto} días · ~${meses} meses${lab==='si'?' · '+laborables+' días laborables':''}</small>`;
}
</script>