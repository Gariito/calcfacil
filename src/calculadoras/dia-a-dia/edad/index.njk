<label>Fecha de nacimiento</label>
<input type="date" id="edad-fecha" oninput="calcEdad()" style="width:100%;padding:0.65rem 0.9rem;border:1px solid var(--border);border-radius:8px;font-size:1rem;background:var(--bg);margin-bottom:1rem">

<div class="result-box" id="edad-res">Introduce tu fecha de nacimiento</div>

<script>
function calcEdad() {
  const val = document.getElementById('edad-fecha').value;
  if (!val) return;
  const hoy = new Date();
  const nac = new Date(val);
  if (nac > hoy) { document.getElementById('edad-res').textContent = 'La fecha es futura'; return; }

  let anos = hoy.getFullYear() - nac.getFullYear();
  let meses = hoy.getMonth() - nac.getMonth();
  let dias = hoy.getDate() - nac.getDate();

  if (dias < 0) { meses--; dias += new Date(hoy.getFullYear(), hoy.getMonth(), 0).getDate(); }
  if (meses < 0) { anos--; meses += 12; }

  const cumple = new Date(hoy.getFullYear(), nac.getMonth(), nac.getDate());
  if (cumple < hoy) cumple.setFullYear(hoy.getFullYear() + 1);
  const diasCumple = Math.round((cumple - hoy) / 86400000);

  const totalDias = Math.round((hoy - nac) / 86400000);

  document.getElementById('edad-res').innerHTML =
    `${anos} años, ${meses} meses y ${dias} días
    <small>${totalDias.toLocaleString('es-ES')} días vividos · Próximo cumpleaños en ${diasCumple} días</small>`;
}
</script>

