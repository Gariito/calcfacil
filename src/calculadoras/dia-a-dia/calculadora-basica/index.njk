<div class="calc-display">
  <div class="expr" id="cb-expr"></div>
  <div class="val" id="cb-val">0</div>
</div>

<div class="kbd-grid">
  <button class="clr" onclick="cbAc()">AC</button>
  <button class="op" onclick="cbOp('+/-')">+/-</button>
  <button class="op" onclick="cbOp('%')">%</button>
  <button class="op" onclick="cbOp('÷')">÷</button>

  <button onclick="cbNum('7')">7</button>
  <button onclick="cbNum('8')">8</button>
  <button onclick="cbNum('9')">9</button>
  <button class="op" onclick="cbOp('×')">×</button>

  <button onclick="cbNum('4')">4</button>
  <button onclick="cbNum('5')">5</button>
  <button onclick="cbNum('6')">6</button>
  <button class="op" onclick="cbOp('−')">−</button>

  <button onclick="cbNum('1')">1</button>
  <button onclick="cbNum('2')">2</button>
  <button onclick="cbNum('3')">3</button>
  <button class="op" onclick="cbOp('+')">+</button>

  <button style="grid-column:span 2" onclick="cbNum('0')">0</button>
  <button onclick="cbDot()">.</button>
  <button class="eq" onclick="cbEq()">=</button>
</div>

<script>
let cb = { v:'0', expr:'', op:null, newN:true };
function cbDisp() {
  document.getElementById('cb-val').textContent = cb.v;
  document.getElementById('cb-expr').textContent = cb.expr;
}
function cbNum(d) {
  if (cb.newN) { cb.v = d; cb.newN = false; }
  else cb.v = cb.v === '0' ? d : cb.v + d;
  cbDisp();
}
function cbDot() {
  if (!cb.v.includes('.')) { cb.v += '.'; cb.newN = false; }
  cbDisp();
}
function cbAc() { cb = {v:'0',expr:'',op:null,newN:true}; cbDisp(); }
function cbOp(o) {
  if (o==='+/-') { cb.v = String(-(parseFloat(cb.v)||0)); cbDisp(); return; }
  if (o==='%') { cb.v = String(parseFloat(cb.v)/100); cbDisp(); return; }
  cbEq();
  cb.op = o; cb.expr = cb.v+' '+o; cb.newN = true; cbDisp();
}
function cbEq() {
  if (!cb.op) return;
  const a = parseFloat(cb.expr), b = parseFloat(cb.v);
  const r = cb.op==='+'?a+b:cb.op==='−'?a-b:cb.op==='×'?a*b:b!==0?a/b:'Error';
  cb = {v:typeof r==='number'?String(parseFloat(r.toFixed(10))):r,expr:'',op:null,newN:true};
  cbDisp();
}
document.addEventListener('keydown', e => {
  if ('0123456789'.includes(e.key)) cbNum(e.key);
  else if (e.key==='.') cbDot();
  else if (e.key==='Enter'||e.key==='=') cbEq();
  else if (e.key==='+') cbOp('+');
  else if (e.key==='-') cbOp('−');
  else if (e.key==='*') cbOp('×');
  else if (e.key==='/') { e.preventDefault(); cbOp('÷'); }
  else if (e.key==='Escape') cbAc();
  else if (e.key==='Backspace') { cb.v=cb.v.length>1?cb.v.slice(0,-1):'0'; cbDisp(); }
});
</script>