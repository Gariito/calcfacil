<script>
let alicia = { v: '0', expr: '', op: null, newN: true };

function aliciaDisp() {
  document.getElementById('alicia-val').textContent = alicia.v;
  document.getElementById('alicia-expr').textContent = alicia.expr;
}

function aliciaNum(d) {
  if (alicia.newN) { alicia.v = d; alicia.newN = false; }
  else alicia.v = alicia.v === '0' ? d : alicia.v + d;
  aliciaDisp();
}

function aliciaDot() {
  if (!alicia.v.includes('.')) { alicia.v += '.'; alicia.newN = false; }
  aliciaDisp();
}

function aliciaAC() {
  alicia = { v: '0', expr: '', op: null, newN: true };
  aliciaDisp();
}

function aliciaPlusMinus() {
  alicia.v = String(-(parseFloat(alicia.v) || 0));
  aliciaDisp();
}

function aliciaOp(o) {
  if (o === '%') {
    alicia.v = String(parseFloat(alicia.v) / 100);
    aliciaDisp();
    return;
  }
  aliciaEq();
  alicia.op = o;
  alicia.expr = alicia.v + ' ' + o;
  alicia.newN = true;
  aliciaDisp();
}

function aliciaEq() {
  if (!alicia.op) return;
  const a = parseFloat(alicia.expr);
  const b = parseFloat(alicia.v);
  let r;
  if (alicia.op === '+') r = a + b;
  else if (alicia.op === '−') r = a - b;
  else if (alicia.op === '×') r = a * b;
  else if (alicia.op === '÷') r = b !== 0 ? a / b : 'Error';
  alicia.expr = alicia.expr + ' ' + alicia.v + ' =';
  alicia.v = typeof r === 'number' ? String(parseFloat(r.toFixed(10))) : r;
  alicia.op = null;
  alicia.newN = true;
  aliciaDisp();
}

document.addEventListener('keydown', e => {
  if ('0123456789'.includes(e.key)) aliciaNum(e.key);
  else if (e.key === '.') aliciaDot();
  else if (e.key === 'Enter' || e.key === '=') aliciaEq();
  else if (e.key === '+') aliciaOp('+');
  else if (e.key === '-') aliciaOp('−');
  else if (e.key === '*') aliciaOp('×');
  else if (e.key === '/') { e.preventDefault(); aliciaOp('÷'); }
  else if (e.key === 'Escape') aliciaAC();
  else if (e.key === 'Backspace') {
    alicia.v = alicia.v.length > 1 ? alicia.v.slice(0, -1) : '0';
    aliciaDisp();
  }
});
</script>