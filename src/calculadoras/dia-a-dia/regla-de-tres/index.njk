<label>Tipo de proporción</label>
<select id="rt-tipo" onchange="calcRT()">
  <option value="directa">Directa — si A sube, B sube</option>
  <option value="inversa">Inversa — si A sube, B baja</option>
</select>

<div style="background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:1.25rem;margin-bottom:1rem">
  <div class="row-2">
    <div><label>Si A =</label><input type="number" id="rt-a" placeholder="3" oninput="calcRT()"></div>
    <div><label>entonces B =</label><input type="number" id="rt-b" placeholder="7" oninput="calcRT()"></div>
  </div>
  <div class="row-2">
    <div><label>Si A =</label><input type="number" id="rt-c" placeholder="5" oninput="calcRT()"></div>
    <div>
      <label>entonces B =</label>
      <div class="result-box" id="rt-x" style="margin-top:0;font-size:1.3rem;min-height:44px">?</div>
    </div>
  </div>
</div>

<div class="result-box" id="rt-res">Introduce los tres valores conocidos</div>

<script>
function calcRT() {
  const a = parseFloat(document.getElementById('rt-a').value);
  const b = parseFloat(document.getElementById('rt-b').value);
  const c = parseFloat(document.getElementById('rt-c').value);
  const tipo = document.getElementById('rt-tipo').value;
  if (!a || !b || !c) return;
  const x = tipo === 'directa' ? (b * c) / a : (a * b) / c;
  const xFmt = parseFloat(x.toFixed(6)).toLocaleString('es-ES', {maximumFractionDigits:4});
  document.getElementById('rt-x').textContent = xFmt;
  document.getElementById('rt-res').innerHTML =
    `X = ${xFmt}<small>Proporción ${tipo}: ${a} → ${b} · ${c} → ${xFmt}</small>`;
}
</script>