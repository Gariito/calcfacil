<label>Introduce un número y su base</label>
<div class="row-2">
  <div>
    <label>Número</label>
    <input type="text" id="cn-num" placeholder="255" oninput="calcConvNum()">
  </div>
  <div>
    <label>Base de origen</label>
    <select id="cn-base" onchange="calcConvNum()">
      <option value="10">Decimal (base 10)</option>
      <option value="2">Binario (base 2)</option>
      <option value="16">Hexadecimal (base 16)</option>
      <option value="8">Octal (base 8)</option>
    </select>
  </div>
</div>

<div class="result-box" id="cn-res">Introduce un número</div>

<script>
function calcConvNum() {
  const num = document.getElementById('cn-num').value.trim().toUpperCase();
  const base = parseInt(document.getElementById('cn-base').value);
  if (!num) return;
  const decimal = parseInt(num, base);
  if (isNaN(decimal)) { document.getElementById('cn-res').textContent = 'Número no válido para esa base'; return; }
  document.getElementById('cn-res').innerHTML =
    `Decimal: ${decimal}
    <small>
    Binario: ${decimal.toString(2)} · 
    Octal: ${decimal.toString(8)} · 
    Hexadecimal: ${decimal.toString(16).toUpperCase()}
    </small>`;
}
</script>