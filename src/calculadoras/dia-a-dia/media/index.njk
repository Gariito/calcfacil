<label>Introduce los números separados por comas o espacios</label>
<input type="text" id="med-nums" placeholder="10, 20, 30, 40, 50" oninput="calcMedia()">

<div class="result-box" id="med-res">Introduce una lista de números</div>

<script>
function calcMedia() {
  const raw = document.getElementById('med-nums').value;
  const nums = raw.split(/[\s,;]+/).map(n => parseFloat(n.replace(',','.'))).filter(n => !isNaN(n));
  if (nums.length === 0) return;
  const suma = nums.reduce((a,b) => a+b, 0);
  const media = suma / nums.length;
  const max = Math.max(...nums);
  const min = Math.min(...nums);
  document.getElementById('med-res').innerHTML =
    `Media: ${parseFloat(media.toFixed(6)).toLocaleString('es-ES', {maximumFractionDigits:4})}
    <small>Suma: ${suma} · Cantidad: ${nums.length} · Máx: ${max} · Mín: ${min}</small>`;
}
</script>

