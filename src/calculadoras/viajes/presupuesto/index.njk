<div class="row-2">
  <div>
    <label>Número de días</label>
    <input type="number" id="pres-dias" placeholder="7" oninput="calcPres()">
  </div>
  <div>
    <label>Número de personas</label>
    <input type="number" id="pres-pers" placeholder="2" oninput="calcPres()">
  </div>
</div>

<label>Alojamiento por noche (€ total)</label>
<input type="number" id="pres-aloj" placeholder="80" oninput="calcPres()">

<label>Comida por persona y día (€)</label>
<input type="number" id="pres-comida" placeholder="30" oninput="calcPres()">

<label>Transporte local por persona y día (€)</label>
<input type="number" id="pres-trans" placeholder="10" oninput="calcPres()">

<label>Ocio y actividades por persona y día (€)</label>
<input type="number" id="pres-ocio" placeholder="20" oninput="calcPres()">

<label>Vuelos y transporte de ida y vuelta (€ total)</label>
<input type="number" id="pres-vuelos" placeholder="300" oninput="calcPres()">

<div class="result-box" id="pres-res">Introduce los datos del viaje</div>

<script>
function calcPres() {
  const dias = parseFloat(document.getElementById('pres-dias').value) || 0;
  const pers = parseFloat(document.getElementById('pres-pers').value) || 1;
  const aloj = parseFloat(document.getElementById('pres-aloj').value) || 0;
  const comida = parseFloat(document.getElementById('pres-comida').value) || 0;
  const trans = parseFloat(document.getElementById('pres-trans').value) || 0;
  const ocio = parseFloat(document.getElementById('pres-ocio').value) || 0;
  const vuelos = parseFloat(document.getElementById('pres-vuelos').value) || 0;
  if (!dias) return;
  const totalAloj = aloj * dias;
  const totalComida = comida * pers * dias;
  const totalTrans = trans * pers * dias;
  const totalOcio = ocio * pers * dias;
  const total = totalAloj + totalComida + totalTrans + totalOcio + vuelos;
  const porPersona = total / pers;
  document.getElementById('pres-res').innerHTML =
    `Total: ${total.toFixed(0)} €<small>
    Por persona: ${porPersona.toFixed(0)} € · 
    Aloj: ${totalAloj.toFixed(0)} € · 
    Comida: ${totalComida.toFixed(0)} € · 
    Trans: ${(totalTrans+vuelos).toFixed(0)} € · 
    Ocio: ${totalOcio.toFixed(0)} €</small>`;
}
</script>