<label>Distancia del trayecto (km)</label>
<input type="number" id="comb-km" placeholder="500" oninput="calcComb()">

<div class="row-2">
  <div>
    <label>Consumo del coche (L/100km)</label>
    <input type="number" id="comb-cons" placeholder="6.5" oninput="calcComb()">
  </div>
  <div>
    <label>Precio del combustible (€/L)</label>
    <input type="number" id="comb-precio" placeholder="1.60" oninput="calcComb()">
  </div>
</div>

<div class="result-box" id="comb-res">Introduce los datos del trayecto</div>

<script>
function calcComb() {
  const km = parseFloat(document.getElementById('comb-km').value);
  const cons = parseFloat(document.getElementById('comb-cons').value);
  const precio = parseFloat(document.getElementById('comb-precio').value);
  if (!km || !cons || !precio) return;
  const litros = (km * cons) / 100;
  const coste = litros * precio;
  document.getElementById('comb-res').innerHTML =
    `${coste.toFixed(2)} €<small>Litros necesarios: ${litros.toFixed(1)} L · ${cons} L/100km durante ${km} km</small>`;
}
</script>