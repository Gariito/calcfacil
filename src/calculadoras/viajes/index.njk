---
layout: base.njk
title: Calculadoras de viajes gratuitas
description: Calculadoras de viajes gratuitas. Combustible, velocidad media y presupuesto de viaje.
keywords: calculadora viajes, combustible, velocidad media, presupuesto viaje
---

<div class="cat-page">
  <div class="container">
    <div class="cat-header">
      <h1>✈️ Calculadoras de viajes</h1>
      <p>Planifica tu próximo viaje con todas las cuentas claras.</p>
    </div>

    <div class="search-wrap">
      <span class="search-icon">🔍</span>
      <input type="text" class="search-input" id="cat-search"
        placeholder="Buscar... combustible, velocidad, presupuesto..."
        oninput="searchCat(this.value)" autocomplete="off">
      <div class="search-count" id="cat-count"></div>
    </div>

    <div class="search-empty" id="cat-empty">
      <div class="empty-icon">🔍</div>
      <p>No se encontraron calculadoras para "<span id="cat-empty-term"></span>"</p>
    </div>

    <div class="calc-cards" id="cat-grid">
      <a class="calc-card-link" href="/calculadoras/viajes/combustible/">
        <span class="icon">⛽</span>
        <div><h2>Calculadora de combustible</h2><p>Calcula el coste de gasolina o diésel para cualquier trayecto.</p></div>
      </a>
      <a class="calc-card-link" href="/calculadoras/viajes/velocidad-media/">
        <span class="icon">🚗</span>
        <div><h2>Calculadora de velocidad media</h2><p>Calcula velocidad, distancia o tiempo de cualquier trayecto.</p></div>
      </a>
      <a class="calc-card-link" href="/calculadoras/viajes/presupuesto/">
        <span class="icon">💰</span>
        <div><h2>Presupuesto de viaje</h2><p>Estima el coste total de tu viaje por días y categorías de gasto.</p></div>
      </a>
    </div>
  </div>
</div>

<script>
function searchCat(q) {
  const term = q.toLowerCase().trim();
  const cards = document.querySelectorAll('#cat-grid .calc-card-link');
  const empty = document.getElementById('cat-empty');
  const count = document.getElementById('cat-count');
  let visible = 0;
  cards.forEach(card => {
    const text = card.textContent.toLowerCase();
    if (!term || text.includes(term)) { card.classList.remove('hidden'); visible++; }
    else card.classList.add('hidden');
  });
  if (term) {
    count.textContent = visible + ' calculadora' + (visible !== 1 ? 's' : '') + ' encontrada' + (visible !== 1 ? 's' : '');
    document.getElementById('cat-empty-term').textContent = q;
    empty.style.display = visible === 0 ? 'block' : 'none';
  } else { count.textContent = ''; empty.style.display = 'none'; }
}
</script>