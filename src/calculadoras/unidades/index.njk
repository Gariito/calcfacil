---

<div class="cat-page">
  <div class="container">
    <div class="cat-header">
      <h1>📐 Conversores de unidades</h1>
      <p>Convierte entre cualquier unidad de medida al instante.</p>
    </div>

    <div class="search-wrap">
      <span class="search-icon">🔍</span>
      <input type="text" class="search-input" id="cat-search"
        placeholder="Buscar... metros, kilos, celsius, litros..."
        oninput="searchCat(this.value)" autocomplete="off">
      <div class="search-count" id="cat-count"></div>
    </div>

    <div class="search-empty" id="cat-empty">
      <div class="empty-icon">🔍</div>
      <p>No se encontraron calculadoras para "<span id="cat-empty-term"></span>"</p>
    </div>

    <div class="calc-cards" id="cat-grid">
      <a class="calc-card-link" href="/calculadoras/unidades/longitud/">
        <span class="icon">📏</span>
        <div><h2>Conversor de longitud</h2><p>Metros, kilómetros, centímetros, millas, pies y pulgadas.</p></div>
      </a>
      <a class="calc-card-link" href="/calculadoras/unidades/peso/">
        <span class="icon">🏋️</span>
        <div><h2>Conversor de peso</h2><p>Kilogramos, gramos, libras, onzas y toneladas.</p></div>
      </a>
      <a class="calc-card-link" href="/calculadoras/unidades/volumen/">
        <span class="icon">🧪</span>
        <div><h2>Conversor de volumen</h2><p>Litros, mililitros, centilitros, galones y más.</p></div>
      </a>
      <a class="calc-card-link" href="/calculadoras/unidades/temperatura/">
        <span class="icon">🌡️</span>
        <div><h2>Conversor de temperatura</h2><p>Celsius, Fahrenheit y Kelvin.</p></div>
      </a>
      <a class="calc-card-link" href="/calculadoras/unidades/velocidad/">
        <span class="icon">🚗</span>
        <div><h2>Conversor de velocidad</h2><p>km/h, m/s, mph y nudos.</p></div>
      </a>
      <a class="calc-card-link" href="/calculadoras/unidades/almacenamiento/">
        <span class="icon">💾</span>
        <div><h2>Almacenamiento digital</h2><p>Bytes, KB, MB, GB y TB.</p></div>
      </a>
      <a class="calc-card-link" href="/calculadoras/unidades/area/">
        <span class="icon">📐</span>
        <div><h2>Conversor de área</h2><p>Metros cuadrados, hectáreas, km², acres y pies cuadrados.</p></div>
      </a>
    </div>
  </div>
</div>

<script>
function searchCat(q) {
  const term = q.toLowerCase().trim();
  const cards = document.querySelectorAll('#cat-grid .calc-card-link');
  const empty = document.getElementById('cat-empty');
  const count = document.getElementById('cat-count');
  let visible = 0;
  cards.forEach(card => {
    const text = card.textContent.toLowerCase();
    if (!term || text.includes(term)) { card.classList.remove('hidden'); visible++; }
    else card.classList.add('hidden');
  });
  if (term) {
    count.textContent = visible + ' calculadora' + (visible !== 1 ? 's' : '') + ' encontrada' + (visible !== 1 ? 's' : '');
    document.getElementById('cat-empty-term').textContent = q;
    empty.style.display = visible === 0 ? 'block' : 'none';
  } else { count.textContent = ''; empty.style.display = 'none'; }
}
</script>