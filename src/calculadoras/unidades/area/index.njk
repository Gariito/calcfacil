<div class="row-2">
  <div>
    <label>Valor</label>
    <input type="number" id="area-val" placeholder="100" oninput="calcArea()">
  </div>
  <div>
    <label>De</label>
    <select id="area-from" onchange="calcArea()">
      <option value="1">Metros cuadrados (m²)</option>
      <option value="10000">Hectáreas (ha)</option>
      <option value="1000000">Kilómetros cuadrados (km²)</option>
      <option value="0.0929">Pies cuadrados (ft²)</option>
      <option value="4046.86">Acres</option>
      <option value="0.000001">Milímetros cuadrados (mm²)</option>
      <option value="0.0001">Centímetros cuadrados (cm²)</option>
    </select>
  </div>
</div>

<label>A</label>
<select id="area-to" onchange="calcArea()">
  <option value="10000">Hectáreas (ha)</option>
  <option value="1">Metros cuadrados (m²)</option>
  <option value="1000000">Kilómetros cuadrados (km²)</option>
  <option value="0.0929">Pies cuadrados (ft²)</option>
  <option value="4046.86">Acres</option>
  <option value="0.000001">Milímetros cuadrados (mm²)</option>
  <option value="0.0001">Centímetros cuadrados (cm²)</option>
</select>

<div class="result-box" id="area-res">Introduce un valor</div>

<script>
function calcArea() {
  const v = parseFloat(document.getElementById('area-val').value);
  const f = parseFloat(document.getElementById('area-from').value);
  const t = parseFloat(document.getElementById('area-to').value);
  if (isNaN(v)) return;
  const res = v * f / t;
  const label = document.getElementById('area-to').options[document.getElementById('area-to').selectedIndex].text;
  document.getElementById('area-res').textContent = `${parseFloat(res.toFixed(8)).toLocaleString('es-ES', {maximumFractionDigits:6})} ${label.split(' ')[0]}`;
}
</script>