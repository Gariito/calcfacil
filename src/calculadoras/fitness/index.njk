<div class="cat-page">
  <div class="container">
    <div class="cat-header">
      <h1>💪 Calculadoras de fitness</h1>
      <p>Optimiza tu entrenamiento y alcanza tus objetivos.</p>
    </div>

    <div class="search-wrap">
      <span class="search-icon">🔍</span>
      <input type="text" class="search-input" id="cat-search"
        placeholder="Buscar... calorías, carrera, fuerza..."
        oninput="searchCat(this.value)" autocomplete="off">
      <div class="search-count" id="cat-count"></div>
    </div>

    <div class="search-empty" id="cat-empty">
      <div class="empty-icon">🔍</div>
      <p>No se encontraron calculadoras para "<span id="cat-empty-term"></span>"</p>
    </div>

    <div class="calc-cards" id="cat-grid">
      <a class="calc-card-link" href="/calculadoras/fitness/calorias-objetivo/">
        <span class="icon">🎯</span>
        <div><h2>Calorías según tu objetivo</h2><p>Calorías exactas para adelgazar, mantener o ganar músculo.</p></div>
      </a>
      <a class="calc-card-link" href="/calculadoras/fitness/calorias-quemadas/">
        <span class="icon">🔥</span>
        <div><h2>Calorías quemadas</h2><p>Calcula las calorías que quemas según el ejercicio, tu peso y la duración.</p></div>
      </a>
      <a class="calc-card-link" href="/calculadoras/fitness/ritmo-carrera/">
        <span class="icon">🏃</span>
        <div><h2>Ritmo de carrera</h2><p>Calcula tu pace, velocidad media y tiempo para cualquier distancia.</p></div>
      </a>
      <a class="calc-card-link" href="/calculadoras/fitness/vo2max/">
        <span class="icon">🫁</span>
        <div><h2>VO2 máximo</h2><p>Estima tu capacidad aeróbica máxima con el test de Cooper.</p></div>
      </a>
      <a class="calc-card-link" href="/calculadoras/fitness/repeticiones-maximas/">
        <span class="icon">🏋️</span>
        <div><h2>1 Repetición máxima (1RM)</h2><p>Calcula tu repetición máxima para cualquier ejercicio de fuerza.</p></div>
      </a>
    </div>
  </div>
</div>

<script>
function searchCat(q) {
  const term = q.toLowerCase().trim();
  const cards = document.querySelectorAll('#cat-grid .calc-card-link');
  const empty = document.getElementById('cat-empty');
  const count = document.getElementById('cat-count');
  let visible = 0;
  cards.forEach(card => {
    const text = card.textContent.toLowerCase();
    if (!term || text.includes(term)) { card.classList.remove('hidden'); visible++; }
    else card.classList.add('hidden');
  });
  if (term) {
    count.textContent = visible + ' calculadora' + (visible !== 1 ? 's' : '') + ' encontrada' + (visible !== 1 ? 's' : '');
    document.getElementById('cat-empty-term').textContent = q;
    empty.style.display = visible === 0 ? 'block' : 'none';
  } else { count.textContent = ''; empty.style.display = 'none'; }
}
</script>