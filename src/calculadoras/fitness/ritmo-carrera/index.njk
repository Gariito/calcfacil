<label>Distancia</label>
<select id="rc-dist" onchange="calcRitmo()">
  <option value="1">1 km</option>
  <option value="5">5 km</option>
  <option value="10">10 km</option>
  <option value="21.097">Media maratón (21,097 km)</option>
  <option value="42.195">Maratón (42,195 km)</option>
</select>

<div class="row-2">
  <div>
    <label>Horas</label>
    <input type="number" id="rc-h" placeholder="0" oninput="calcRitmo()">
  </div>
  <div>
    <label>Minutos</label>
    <input type="number" id="rc-m" placeholder="25" oninput="calcRitmo()">
  </div>
</div>

<label>Segundos</label>
<input type="number" id="rc-s" placeholder="0" oninput="calcRitmo()">

<div class="result-box" id="rc-res">Introduce la distancia y el tiempo</div>

<script>
function calcRitmo() {
  const dist = parseFloat(document.getElementById('rc-dist').value);
  const h = parseFloat(document.getElementById('rc-h').value) || 0;
  const m = parseFloat(document.getElementById('rc-m').value) || 0;
  const s = parseFloat(document.getElementById('rc-s').value) || 0;
  const totalSeg = h * 3600 + m * 60 + s;
  if (!totalSeg || !dist) return;
  const paceSeg = totalSeg / dist;
  const paceMin = Math.floor(paceSeg / 60);
  const paceSec = Math.round(paceSeg % 60).toString().padStart(2, '0');
  const vel = (dist / (totalSeg / 3600)).toFixed(2);
  document.getElementById('rc-res').innerHTML =
    `Pace: ${paceMin}:${paceSec} min/km<small>Velocidad media: ${vel} km/h</small>`;
}
</script>