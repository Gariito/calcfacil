<label>Peso levantado (kg)</label>
<input type="number" id="rm-peso" placeholder="80" oninput="calcRM()">

<label>Número de repeticiones realizadas</label>
<input type="number" id="rm-reps" placeholder="8" oninput="calcRM()">

<div class="result-box" id="rm-res">Introduce el peso y las repeticiones</div>

<script>
function calcRM() {
  const peso = parseFloat(document.getElementById('rm-peso').value);
  const reps = parseFloat(document.getElementById('rm-reps').value);
  if (!peso || !reps) return;
  const rm = peso * (1 + reps / 30);
  document.getElementById('rm-res').innerHTML =
    `1RM estimado: ${rm.toFixed(1)} kg<small>
    50% → ${(rm*0.5).toFixed(1)} kg · 
    65% → ${(rm*0.65).toFixed(1)} kg · 
    75% → ${(rm*0.75).toFixed(1)} kg · 
    85% → ${(rm*0.85).toFixed(1)} kg · 
    90% → ${(rm*0.9).toFixed(1)} kg</small>`;
}
</script>