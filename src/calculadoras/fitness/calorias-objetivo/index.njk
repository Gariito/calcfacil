<div class="row-2">
  <div>
    <label>Peso (kg)</label>
    <input type="number" id="co-peso" placeholder="75" oninput="calcCO()">
  </div>
  <div>
    <label>Altura (cm)</label>
    <input type="number" id="co-altura" placeholder="175" oninput="calcCO()">
  </div>
</div>

<div class="row-2">
  <div>
    <label>Edad (años)</label>
    <input type="number" id="co-edad" placeholder="30" oninput="calcCO()">
  </div>
  <div>
    <label>Sexo</label>
    <select id="co-sexo" onchange="calcCO()">
      <option value="h">Hombre</option>
      <option value="m">Mujer</option>
    </select>
  </div>
</div>

<label>Nivel de actividad</label>
<select id="co-act" onchange="calcCO()">
  <option value="1.2">Sedentario (sin ejercicio)</option>
  <option value="1.375">Ligero (1-3 días/semana)</option>
  <option value="1.55">Moderado (3-5 días/semana)</option>
  <option value="1.725">Activo (6-7 días/semana)</option>
  <option value="1.9">Muy activo (doble entrenamiento)</option>
</select>

<label>Tu objetivo</label>
<select id="co-obj" onchange="calcCO()">
  <option value="-500">Pérdida de peso rápida (−500 kcal)</option>
  <option value="-300">Pérdida de peso gradual (−300 kcal)</option>
  <option value="0">Mantenimiento (0 kcal)</option>
  <option value="200">Ganancia muscular ligera (+200 kcal)</option>
  <option value="400">Ganancia muscular (volumen) (+400 kcal)</option>
</select>

<div class="result-box" id="co-res">Introduce tus datos</div>

<script>
function calcCO() {
  const peso = parseFloat(document.getElementById('co-peso').value);
  const altura = parseFloat(document.getElementById('co-altura').value);
  const edad = parseFloat(document.getElementById('co-edad').value);
  const sexo = document.getElementById('co-sexo').value;
  const act = parseFloat(document.getElementById('co-act').value);
  const obj = parseInt(document.getElementById('co-obj').value);
  if (!peso||!altura||!edad) return;

  const tmb = sexo==='h'
    ? 10*peso + 6.25*altura - 5*edad + 5
    : 10*peso + 6.25*altura - 5*edad - 161;

  const mantenimiento = Math.round(tmb * act);
  const objetivo = mantenimiento + obj;
  const proteinas = Math.round(peso * (obj < 0 ? 2.2 : obj > 0 ? 2.0 : 1.8));
  const grasas = Math.round(objetivo * 0.25 / 9);
  const carbos = Math.round((objetivo - proteinas*4 - grasas*9) / 4);

  document.getElementById('co-res').innerHTML =
    `${objetivo.toLocaleString('es-ES')} kcal/día
    <small>
    Mantenimiento: ${mantenimiento.toLocaleString('es-ES')} kcal · 
    Proteínas: ${proteinas}g · 
    Grasas: ${grasas}g · 
    Carbos: ${carbos}g
    </small>`;
}
</script>