<label>Método de estimación</label>
<select id="vo2-metodo" onchange="toggleVO2()">
  <option value="cooper">Test de Cooper (distancia en 12 min)</option>
  <option value="pace">Por pace de carrera</option>
</select>

<div id="vo2-cooper">
  <label>Distancia recorrida en 12 minutos (metros)</label>
  <input type="number" id="vo2-dist" placeholder="2400" oninput="calcVO2()">
</div>

<div id="vo2-pace" style="display:none">
  <div class="row-2">
    <div>
      <label>Pace (minutos)</label>
      <input type="number" id="vo2-pm" placeholder="5" oninput="calcVO2()">
    </div>
    <div>
      <label>Pace (segundos)</label>
      <input type="number" id="vo2-ps" placeholder="0" oninput="calcVO2()">
    </div>
  </div>
</div>

<div class="result-box" id="vo2-res">Introduce tus datos</div>

<script>
function toggleVO2() {
  const m = document.getElementById('vo2-metodo').value;
  document.getElementById('vo2-cooper').style.display = m === 'cooper' ? 'block' : 'none';
  document.getElementById('vo2-pace').style.display = m === 'pace' ? 'block' : 'none';
  calcVO2();
}
function calcVO2() {
  const metodo = document.getElementById('vo2-metodo').value;
  let vo2;
  if (metodo === 'cooper') {
    const dist = parseFloat(document.getElementById('vo2-dist').value);
    if (!dist) return;
    vo2 = (dist - 504.9) / 44.73;
  } else {
    const pm = parseFloat(document.getElementById('vo2-pm').value) || 0;
    const ps = parseFloat(document.getElementById('vo2-ps').value) || 0;
    const paceSeg = pm * 60 + ps;
    if (!paceSeg) return;
    const vel = 1000 / paceSeg * 60;
    vo2 = -4.6 + 0.182258 * vel + 0.000104 * vel * vel;
  }
  const nivel = vo2 < 30 ? 'Bajo' : vo2 < 40 ? 'Regular' : vo2 < 50 ? 'Bueno' : vo2 < 60 ? 'Muy bueno' : 'Excelente';
  document.getElementById('vo2-res').innerHTML =
    `VO2 máx: ${vo2.toFixed(1)} ml/kg/min<small>Nivel: ${nivel}</small>`;
}
</script>