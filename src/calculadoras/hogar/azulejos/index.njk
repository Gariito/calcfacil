---

<div class="row-2">
  <div>
    <label>Ancho de la superficie (m)</label>
    <input type="number" id="az-ancho" placeholder="3" oninput="calcAzulejos()">
  </div>
  <div>
    <label>Alto de la superficie (m)</label>
    <input type="number" id="az-alto" placeholder="2.4" oninput="calcAzulejos()">
  </div>
</div>

<div class="row-2">
  <div>
    <label>Ancho del azulejo (cm)</label>
    <input type="number" id="az-w" placeholder="30" oninput="calcAzulejos()">
  </div>
  <div>
    <label>Alto del azulejo (cm)</label>
    <input type="number" id="az-h" placeholder="60" oninput="calcAzulejos()">
  </div>
</div>

<label>Merma por cortes (%)</label>
<select id="az-merma" onchange="calcAzulejos()">
  <option value="10">10% — Colocación recta sencilla</option>
  <option value="15">15% — Colocación en offset o juntas</option>
  <option value="20">20% — Colocación en diagonal o espiga</option>
</select>

<div class="result-box" id="az-res">Introduce las medidas</div>

<script>
function calcAzulejos() {
  const sw = parseFloat(document.getElementById('az-ancho').value);
  const sh = parseFloat(document.getElementById('az-alto').value);
  const tw = parseFloat(document.getElementById('az-w').value) / 100;
  const th = parseFloat(document.getElementById('az-h').value) / 100;
  const merma = parseFloat(document.getElementById('az-merma').value) / 100;
  if (!sw || !sh || !tw || !th) return;
  const superfTotal = sw * sh;
  const areaAzulejo = tw * th;
  const cantidad = Math.ceil((superfTotal / areaAzulejo) * (1 + merma));
  document.getElementById('az-res').innerHTML =
    `${cantidad} azulejos<small>Superficie: ${superfTotal.toFixed(2)} m² · Por azulejo: ${(areaAzulejo*10000).toFixed(0)} cm²</small>`;
}
</script>