    <input type="number" id="hva-entrada" placeholder="40000" oninput="calcHvA()">
    <label>Tipo de interés hipoteca (%)</label>
    <input type="number" id="hva-interes" placeholder="3.5" oninput="calcHvA()">
    <label>Gastos anuales propietario (IBI, comunidad…) (€)</label>
    <input type="number" id="hva-gastos" placeholder="1500" oninput="calcHvA()">
  </div>
  <div>
    <p style="font-weight:600;margin-bottom:1rem;color:#16A34A">🔑 Alquilar</p>
