    <input type="number" id="hva-alquiler" placeholder="900" oninput="calcHvA()">
    <label>Subida anual del alquiler (%)</label>
    <input type="number" id="hva-subida" placeholder="3" oninput="calcHvA()">
    <label>Rendimiento inversión entrada (%)</label>
    <input type="number" id="hva-rent" placeholder="4" oninput="calcHvA()">
  </div>
</div>

<label style="margin-top:1rem">Años de comparación</label>
<input type="number" id="hva-anos" placeholder="20" oninput="calcHvA()">

<div class="result-box" id="hva-res">Introduce los datos de ambas opciones</div>

<script>
function calcHvA() {
  const precio = parseFloat(document.getElementById('hva-precio').value);
  const entrada = parseFloat(document.getElementById('hva-entrada').value);
  const interes = parseFloat(document.getElementById('hva-interes').value) / 100 / 12;
  const gastos = parseFloat(document.getElementById('hva-gastos').value) || 0;
  const alquiler = parseFloat(document.getElementById('hva-alquiler').value);
  const subida = parseFloat(document.getElementById('hva-subida').value) / 100;
  const rent = parseFloat(document.getElementById('hva-rent').value) / 100;
  const anos = parseFloat(document.getElementById('hva-anos').value);
  if (!precio||!entrada||!alquiler||!anos) return;

  const prestamo = precio - entrada;
  const n = anos * 12;
  const cuota = prestamo * interes * Math.pow(1+interes,n) / (Math.pow(1+interes,n)-1);
  const totalHipoteca = cuota * n + gastos * anos + entrada;
  const valorFinal = precio * Math.pow(1.03, anos);
  const costeNetoCompra = totalHipoteca - valorFinal;

  let totalAlquiler = 0, alqMes = alquiler;
  for (let i = 0; i < anos; i++) { totalAlquiler += alqMes * 12; alqMes *= (1 + subida); }
  const gananciainversion = entrada * (Math.pow(1 + rent, anos) - 1);
  const costeNetoAlquiler = totalAlquiler - gananciainversion;

  const mejor = costeNetoCompra < costeNetoAlquiler ? 'COMPRAR' : 'ALQUILAR';
  const dif = Math.abs(costeNetoCompra - costeNetoAlquiler);
  const color = mejor === 'COMPRAR' ? '#2563EB' : '#16A34A';

  document.getElementById('hva-res').innerHTML =
    `<span style="color:${color}">En ${anos} años, sale mejor ${mejor}</span>
    <small>
    Coste neto compra: ${costeNetoCompra.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g,'.')} € · 
    Coste neto alquiler: ${costeNetoAlquiler.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g,'.')} € · 
    Diferencia: ${dif.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g,'.')} €
    </small>`;
}
</script>