<label>Potencia del aparato (vatios W)</label>
<input type="number" id="ele-w" placeholder="1500" oninput="calcElec()">

<div class="row-2">
  <div>
    <label>Horas de uso al día</label>
    <input type="number" id="ele-h" placeholder="2" oninput="calcElec()">
  </div>
  <div>
    <label>Precio del kWh (€)</label>
    <input type="number" id="ele-precio" placeholder="0.20" value="0.20" oninput="calcElec()">
  </div>
</div>

<div class="result-box" id="ele-res">Introduce la potencia y las horas de uso</div>

<script>
function calcElec() {
  const w = parseFloat(document.getElementById('ele-w').value);
  const h = parseFloat(document.getElementById('ele-h').value);
  const precio = parseFloat(document.getElementById('ele-precio').value) || 0.20;
  if (!w || !h) return;
  const kwh_dia = (w * h) / 1000;
  const kwh_mes = kwh_dia * 30;
  const kwh_año = kwh_dia * 365;
  document.getElementById('ele-res').innerHTML =
    `${kwh_dia.toFixed(3)} kWh/día<small>
    Mes: ${kwh_mes.toFixed(2)} kWh → ${(kwh_mes*precio).toFixed(2)} € · 
    Año: ${kwh_año.toFixed(1)} kWh → ${(kwh_año*precio).toFixed(2)} €</small>`;
}
</script>