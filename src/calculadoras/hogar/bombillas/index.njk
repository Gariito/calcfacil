<div class="row-2">
  <div>
    <label>Potencia actual (W)</label>
    <input type="number" id="led-actual" placeholder="60" oninput="calcLED()">
  </div>
  <div>
    <label>Tipo de bombilla actual</label>
    <select id="led-tipo" onchange="calcLED()">
      <option value="incandescente">Incandescente</option>
      <option value="halogeno">Halógeno</option>
      <option value="fluorescente">Fluorescente (bajo consumo)</option>
    </select>
  </div>
</div>

<div class="row-2">
  <div>
    <label>Número de bombillas</label>
    <input type="number" id="led-num" placeholder="10" oninput="calcLED()">
  </div>
  <div>
    <label>Horas de uso al día</label>
    <input type="number" id="led-horas" placeholder="4" oninput="calcLED()">
  </div>
</div>

<label>Precio del kWh (€)</label>
<input type="number" id="led-precio" placeholder="0.20" value="0.20" oninput="calcLED()">

<div class="result-box" id="led-res">Introduce los datos de tus bombillas</div>

<script>
function calcLED() {
  const actual = parseFloat(document.getElementById('led-actual').value);
  const tipo = document.getElementById('led-tipo').value;
  const num = parseFloat(document.getElementById('led-num').value) || 1;
  const horas = parseFloat(document.getElementById('led-horas').value) || 4;
  const precio = parseFloat(document.getElementById('led-precio').value) || 0.20;
  if (!actual) return;

  const factorLED = tipo === 'incandescente' ? 0.15 : tipo === 'halogeno' ? 0.25 : 0.5;
  const wattsLED = actual * factorLED;

  const consumoActual = actual * num * horas / 1000;
  const consumoLED = wattsLED * num * horas / 1000;
  const ahorroKwh = consumoActual - consumoLED;
  const ahorroAnual = ahorroKwh * 365 * precio;
  const pctAhorro = ((ahorroKwh / consumoActual) * 100).toFixed(0);

  document.getElementById('led-res').innerHTML =
    `Ahorro anual: ${ahorroAnual.toFixed(2)} €
    <small>
    Equivalente LED: ${wattsLED.toFixed(0)}W · 
    Ahorro energético: ${pctAhorro}% · 
    ${(ahorroKwh * 365).toFixed(0)} kWh/año menos
    </small>`;
}
</script>