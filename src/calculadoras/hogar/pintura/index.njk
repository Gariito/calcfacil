<div class="row-2">
  <div>
    <label>Ancho de la habitación (m)</label>
    <input type="number" id="pin-ancho" placeholder="4" oninput="calcPintura()">
  </div>
  <div>
    <label>Largo de la habitación (m)</label>
    <input type="number" id="pin-largo" placeholder="5" oninput="calcPintura()">
  </div>
</div>

<label>Altura de las paredes (m)</label>
<input type="number" id="pin-alto" placeholder="2.5" oninput="calcPintura()">

<div class="row-2">
  <div>
    <label>Número de puertas</label>
    <input type="number" id="pin-puertas" placeholder="1" value="1" oninput="calcPintura()">
  </div>
  <div>
    <label>Número de ventanas</label>
    <input type="number" id="pin-ventanas" placeholder="1" value="1" oninput="calcPintura()">
  </div>
</div>

<div class="row-2">
  <div>
    <label>Número de manos</label>
    <input type="number" id="pin-manos" placeholder="2" value="2" oninput="calcPintura()">
  </div>
  <div>
    <label>Rendimiento (m²/litro)</label>
    <input type="number" id="pin-rend" placeholder="10" value="10" oninput="calcPintura()">
  </div>
</div>

<div class="result-box" id="pin-res">Introduce las medidas</div>

<script>
function calcPintura() {
  const a = parseFloat(document.getElementById('pin-ancho').value);
  const l = parseFloat(document.getElementById('pin-largo').value);
  const h = parseFloat(document.getElementById('pin-alto').value);
  const puertas = (parseFloat(document.getElementById('pin-puertas').value) || 0) * 1.85;
  const ventanas = (parseFloat(document.getElementById('pin-ventanas').value) || 0) * 1.2;
  const manos = parseFloat(document.getElementById('pin-manos').value) || 2;
  const rend = parseFloat(document.getElementById('pin-rend').value) || 10;
  if (!a || !l || !h) return;
  const superfParedes = 2 * (a + l) * h;
  const superfNeta = superfParedes - puertas - ventanas;
  const litros = (superfNeta * manos) / rend;
  const litrosExtra = litros * 1.1;
  document.getElementById('pin-res').innerHTML =
    `${litros.toFixed(1)} litros<small>Superficie: ${superfNeta.toFixed(1)} m² · Con 10% extra: ${litrosExtra.toFixed(1)} L</small>`;
}
</script>