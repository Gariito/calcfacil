<label>Sexo</label>
<select id="gc-sexo" onchange="toggleGC()">
  <option value="h">Hombre</option>
  <option value="m">Mujer</option>
</select>

<label>Altura (cm)</label>
<input type="number" id="gc-altura" placeholder="175" oninput="calcGC()">

<label>Perímetro de cintura (cm)</label>
<input type="number" id="gc-cintura" placeholder="85" oninput="calcGC()">

<label>Perímetro de cuello (cm)</label>
<input type="number" id="gc-cuello" placeholder="38" oninput="calcGC()">

<div id="gc-cadera-wrap">
  <label>Perímetro de cadera (cm) <span style="color:var(--muted);font-size:0.8rem">— solo mujeres</span></label>
  <input type="number" id="gc-cadera" placeholder="95" oninput="calcGC()">
</div>

<div class="result-box" id="gc-res">Introduce tus medidas</div>

<script>
function toggleGC() {
  const sexo = document.getElementById('gc-sexo').value;
  document.getElementById('gc-cadera-wrap').style.display = sexo === 'm' ? 'block' : 'none';
  calcGC();
}
toggleGC();

function calcGC() {
  const sexo = document.getElementById('gc-sexo').value;
  const altura = parseFloat(document.getElementById('gc-altura').value);
  const cintura = parseFloat(document.getElementById('gc-cintura').value);
  const cuello = parseFloat(document.getElementById('gc-cuello').value);
  const cadera = parseFloat(document.getElementById('gc-cadera')?.value);
  if (!altura || !cintura || !cuello) return;
  if (sexo === 'm' && !cadera) return;

  let grasa;
  if (sexo === 'h') {
    grasa = 495 / (1.0324 - 0.19077 * Math.log10(cintura - cuello) + 0.15456 * Math.log10(altura)) - 450;
  } else {
    grasa = 495 / (1.29579 - 0.35004 * Math.log10(cintura + cadera - cuello) + 0.22100 * Math.log10(altura)) - 450;
  }

  if (isNaN(grasa) || grasa < 0) { document.getElementById('gc-res').textContent = 'Revisa las medidas introducidas'; return; }

  let cat, color;
  if (sexo === 'h') {
    cat = grasa < 6 ? 'Esencial' : grasa < 14 ? 'Deportista' : grasa < 21 ? 'En forma' : grasa < 25 ? 'Aceptable' : 'Obesidad';
    color = grasa < 21 ? '#22C55E' : grasa < 25 ? '#EAB308' : '#EF4444';
  } else {
    cat = grasa < 14 ? 'Esencial' : grasa < 21 ? 'Deportista' : grasa < 25 ? 'En forma' : grasa < 32 ? 'Aceptable' : 'Obesidad';
    color = grasa < 25 ? '#22C55E' : grasa < 32 ? '#EAB308' : '#EF4444';
  }

  document.getElementById('gc-res').innerHTML =
    `<span style="color:${color}">${grasa.toFixed(1)}% grasa — ${cat}</span>
    <small>Masa grasa estimada · Fórmula Marina EE.UU.</small>`;
}
</script>

<div style="margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--border)">
          
          
          <h2 style="font-family:var(--font-display);font-size:1.2rem;font-weight:700;margin-bottom:1rem">Guía completa sobre la grasa corporal y la composición física</h2>
          <p style="color:var(--muted);font-size:0.9rem;line-height:1.8;margin-bottom:0.75rem">Conocer el porcentaje de grasa corporal es la forma más precisa de evaluar el estado físico de una persona. A diferencia del peso total en la báscula o del IMC, este indicador separa la masa magra (músculos, huesos, órganos internos y agua) del tejido graso acumulado.</p>
          <p style="color:var(--muted);font-size:0.9rem;line-height:1.8;margin-bottom:0.75rem">Nuestra calculadora de grasa corporal online utiliza el método de la US Navy (Marina de los EE. UU.), una de las fórmulas antropométricas más estudiadas y validadas científicamente para estimar la densidad corporal a partir de perímetros con cinta métrica.</p>

          <h2 style="font-family:var(--font-display);font-size:1.2rem;font-weight:700;margin-bottom:1rem">Grasa esencial vs. Grasa de almacenamiento: ¿Por qué es necesaria la grasa?</h2>
          <p style="color:var(--muted);font-size:0.9rem;line-height:1.8;margin-bottom:0.75rem">El tejido adiposo no es solo un reservorio calórico, sino un órgano endocrino vital para el organismo. Se divide principalmente en dos tipos:</p>
          <p style="color:var(--muted);font-size:0.9rem;line-height:1.8;margin-bottom:0.75rem"><strong>Grasa Esencial:</strong> Es el nivel mínimo indispensable para mantener la vida y las funciones reproductivas, la regulación térmica, el aislamiento de órganos y la producción hormonal. Se estima en un <code>2% - 5%</code> en hombres y un <code>10% - 13%</code> en mujeres.</p>
          <p style="color:var(--muted);font-size:0.9rem;line-height:1.8;margin-bottom:0.75rem"><strong><strong>Grasa de Almacenamiento (Subcutánea y Visceral):</strong> Se deposita bajo la piel y rodeando los órganos vitales. Aunque una reserva óptima protege el cuerpo, un exceso de grasa visceral incrementa directamente el riesgo de enfermedades metabólicas y cardiovasculares.</p>


