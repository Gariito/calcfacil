<label>Alimento</label>
<select id="cal-alim" onchange="calcCalAlim()">
  <optgroup label="Carnes y pescados">
    <option value="165">Pollo (pechuga, cocida)</option>
    <option value="242">Ternera (solomillo)</option>
    <option value="290">Cerdo (lomo)</option>
    <option value="208">Salmón</option>
    <option value="82">Merluza</option>
    <option value="105">Atún al natural</option>
    <option value="144">Sardinas</option>
    <option value="85">Gambas</option>
  </optgroup>
  <optgroup label="Huevos y lácteos">
    <option value="155">Huevo entero</option>
    <option value="61">Leche entera</option>
    <option value="36">Leche desnatada</option>
    <option value="98">Yogur natural</option>
    <option value="402">Queso manchego</option>
    <option value="98">Queso fresco</option>
    <option value="717">Mantequilla</option>
  </optgroup>
  <optgroup label="Cereales y legumbres">
    <option value="130">Arroz cocido</option>
    <option value="158">Pasta cocida</option>
    <option value="265">Pan blanco</option>
    <option value="247">Pan integral</option>
    <option value="354">Avena</option>
    <option value="116">Lentejas cocidas</option>
    <option value="127">Garbanzos cocidos</option>
  </optgroup>
  <optgroup label="Frutas">
    <option value="52">Manzana</option>
    <option value="89">Plátano</option>
    <option value="50">Naranja</option>
    <option value="32">Fresa</option>
    <option value="60">Uva</option>
    <option value="45">Sandía</option>
    <option value="134">Aguacate</option>
  </optgroup>
  <optgroup label="Verduras">
    <option value="25">Tomate</option>
    <option value="41">Zanahoria</option>
    <option value="20">Lechuga</option>
    <option value="34">Pimiento</option>
    <option value="86">Patata cocida</option>
    <option value="25">Espinacas</option>
    <option value="34">Brócoli</option>
  </optgroup>
  <optgroup label="Grasas y aceites">
    <option value="884">Aceite de oliva</option>
    <option value="567">Almendras</option>
    <option value="654">Nueces</option>
    <option value="593">Cacahuetes</option>
  </optgroup>
</select>

<label>Cantidad (gramos)</label>
<input type="number" id="cal-alim-g" placeholder="100" oninput="calcCalAlim()">

<div class="result-box" id="cal-alim-res">Selecciona un alimento e introduce la cantidad</div>

<script>
function calcCalAlim() {
  const kcalPor100 = parseFloat(document.getElementById('cal-alim').value);
  const g = parseFloat(document.getElementById('cal-alim-g').value);
  const nombre = document.getElementById('cal-alim').options[document.getElementById('cal-alim').selectedIndex].text;
  if (!g) { document.getElementById('cal-alim-res').innerHTML = `${nombre}: ${kcalPor100} kcal/100g`; return; }
  const total = (kcalPor100 * g / 100);
  document.getElementById('cal-alim-res').innerHTML =
    `${total.toFixed(0)} kcal
    <small>${g}g de ${nombre} · ${kcalPor100} kcal por 100g</small>`;
}
</script>