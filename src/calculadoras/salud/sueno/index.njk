<label>¿Qué quieres calcular?</label>
<select id="sue-modo" onchange="toggleSueno()">
  <option value="despertar">Me acuesto ahora → ¿a qué hora despertarme?</option>
  <option value="acostar">Quiero levantarme a → ¿a qué hora acostarme?</option>
</select>

<div id="sue-hora-wrap">
  <label id="sue-hora-label">Hora a la que te vas a acostar</label>
  <input type="time" id="sue-hora" oninput="calcSueno()" style="width:100%;padding:0.65rem 0.9rem;border:1px solid var(--border);border-radius:8px;font-size:1rem;background:var(--bg);margin-bottom:1rem">
</div>

<div class="result-box" id="sue-res">Introduce la hora</div>

<div style="margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--border)">
  <h3 style="font-size:1rem;font-weight:600;margin-bottom:1rem">Recomendaciones de sueño por edad</h3>
  <p style="font-size:0.875rem;color:var(--muted);margin-bottom:0.4rem">👶 <strong>Bebés (0-12 meses):</strong> 12-16 horas</p>
  <p style="font-size:0.875rem;color:var(--muted);margin-bottom:0.4rem">🧒 <strong>Niños (6-12 años):</strong> 9-12 horas</p>
  <p style="font-size:0.875rem;color:var(--muted);margin-bottom:0.4rem">🧑 <strong>Adolescentes (13-18 años):</strong> 8-10 horas</p>
  <p style="font-size:0.875rem;color:var(--muted);margin-bottom:0.4rem">🧑‍💼 <strong>Adultos (18-64 años):</strong> 7-9 horas</p>
  <p style="font-size:0.875rem;color:var(--muted)">👴 <strong>Mayores de 65 años:</strong> 7-8 horas</p>
</div>

<script>
function toggleSueno() {
  const modo = document.getElementById('sue-modo').value;
  document.getElementById('sue-hora-label').textContent =
    modo === 'despertar' ? 'Hora a la que te vas a acostar' : 'Hora a la que quieres levantarte';
  calcSueno();
}
function calcSueno() {
  const modo = document.getElementById('sue-modo').value;
  const horaVal = document.getElementById('sue-hora').value;
  if (!horaVal) return;
  const [h, m] = horaVal.split(':').map(Number);
  const base = h * 60 + m + 15; // 15 min para dormirse
  const ciclo = 90;
  const horas = [];
  for (let i = 4; i <= 6; i++) {
    const total = modo === 'despertar' ? base + i * ciclo : base - i * ciclo;
    const min = ((total % 1440) + 1440) % 1440;
    const hh = String(Math.floor(min / 60)).padStart(2, '0');
    const mm = String(min % 60).padStart(2, '0');
    horas.push(`${hh}:${mm} (${i} ciclos, ${i * 1.5}h)`);
  }
  const label = modo === 'despertar' ? 'Horas ideales para despertarte' : 'Horas ideales para acostarte';
  document.getElementById('sue-res').innerHTML =
    `${label}:<small>${horas.join(' · ')}</small>`;
}
</script>