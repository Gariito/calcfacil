<div class="row-2">
  <div>
    <label>Peso (kg)</label>
    <input type="number" id="alc-peso" placeholder="70" oninput="calcAlcohol()">
  </div>
  <div>
    <label>Sexo</label>
    <select id="alc-sexo" onchange="calcAlcohol()">
      <option value="0.68">Hombre</option>
      <option value="0.55">Mujer</option>
    </select>
  </div>
</div>

<label>Horas desde la primera bebida</label>
<input type="number" id="alc-horas" placeholder="2" oninput="calcAlcohol()">

<div style="background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:1rem;margin-bottom:1rem">
  <p style="font-size:0.85rem;font-weight:600;margin-bottom:0.75rem">Bebidas consumidas</p>
  <div class="row-2">
    <div><label>Cervezas (330ml, 5%)</label><input type="number" id="alc-cerv" placeholder="0" value="0" oninput="calcAlcohol()"></div>
    <div><label>Vinos (150ml, 12%)</label><input type="number" id="alc-vino" placeholder="0" value="0" oninput="calcAlcohol()"></div>
  </div>
  <div class="row-2">
    <div><label>Copas licor (50ml, 40%)</label><input type="number" id="alc-copa" placeholder="0" value="0" oninput="calcAlcohol()"></div>
    <div><label>Chupitos (25ml, 40%)</label><input type="number" id="alc-chup" placeholder="0" value="0" oninput="calcAlcohol()"></div>
  </div>
</div>

<div class="result-box" id="alc-res">Introduce tus datos</div>

<div style="margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--border)">
  <h3 style="font-size:1rem;font-weight:600;margin-bottom:1rem">Límites legales en España</h3>
  <p style="font-size:0.875rem;color:var(--muted);margin-bottom:0.5rem">🚗 <strong>Conductores generales:</strong> 0,5 g/L en sangre</p>
  <p style="font-size:0.875rem;color:var(--muted);margin-bottom:0.5rem">🚌 <strong>Conductores noveles y profesionales:</strong> 0,3 g/L en sangre</p>
  <p style="font-size:0.875rem;color:var(--muted)">⚠️ Esta calculadora es orientativa. No conduzcas si has bebido.</p>
</div>

<script>
function calcAlcohol() {
  const peso = parseFloat(document.getElementById('alc-peso').value);
  const r = parseFloat(document.getElementById('alc-sexo').value);
  const horas = parseFloat(document.getElementById('alc-horas').value) || 0;
  const cerv = (parseFloat(document.getElementById('alc-cerv').value) || 0) * 330 * 0.05 * 0.789;
  const vino = (parseFloat(document.getElementById('alc-vino').value) || 0) * 150 * 0.12 * 0.789;
  const copa = (parseFloat(document.getElementById('alc-copa').value) || 0) * 50 * 0.40 * 0.789;
  const chup = (parseFloat(document.getElementById('alc-chup').value) || 0) * 25 * 0.40 * 0.789;
  if (!peso) return;

  const grAlcohol = (cerv + vino + copa + chup) / 1000;
  const bacBruto = (grAlcohol / (peso * r)) * 100;
  const eliminado = 0.15 * horas;
  const bac = Math.max(0, bacBruto - eliminado);

  let estado, color;
  if (bac === 0) { estado = 'Sin alcohol detectable ✓'; color = '#22C55E'; }
  else if (bac < 0.3) { estado = 'Muy bajo — por debajo del límite'; color = '#22C55E'; }
  else if (bac < 0.5) { estado = 'Bajo — cercano al límite general'; color = '#EAB308'; }
  else if (bac < 0.8) { estado = 'Moderado — supera el límite legal'; color = '#EF4444'; }
  else if (bac < 1.5) { estado = 'Alto — deterioro notable'; color = '#DC2626'; }
  else { estado = 'Muy alto — peligroso'; color = '#7C3AED'; }

  const horasElim = bac > 0 ? (bac / 0.15).toFixed(1) : 0;

  document.getElementById('alc-res').innerHTML =
    `<span style="color:${color}">BAC: ${bac.toFixed(2)} g/L — ${estado}</span>
    <small>${bac > 0 ? `Tiempo para eliminar: ~${horasElim} horas más` : 'Puedes conducir con seguridad'}</small>`;
}
</script>