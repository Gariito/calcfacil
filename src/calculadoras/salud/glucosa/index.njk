---

<label>Momento de la medición</label>
<select id="glu-momento" onchange="calcGlucosa()">
  <option value="ayunas">En ayunas (más de 8 horas sin comer)</option>
  <option value="postprandial">2 horas después de comer</option>
  <option value="aleatoria">Medición aleatoria</option>
</select>

<label>Nivel de glucosa (mg/dL)</label>
<input type="number" id="glu-val" placeholder="95" oninput="calcGlucosa()">

<div class="result-box" id="glu-res">Introduce tu nivel de glucosa</div>

<div style="margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--border)">
  <h3 style="font-size:1rem;font-weight:600;margin-bottom:1rem">Valores de referencia (mg/dL)</h3>
  <table style="width:100%;font-size:0.825rem;border-collapse:collapse">
    <tr style="background:var(--bg)">
      <th style="padding:0.5rem;text-align:left;border-bottom:1px solid var(--border)">Categoría</th>
      <th style="padding:0.5rem;text-align:center;border-bottom:1px solid var(--border)">En ayunas</th>
      <th style="padding:0.5rem;text-align:center;border-bottom:1px solid var(--border)">2h después</th>
    </tr>
    <tr><td style="padding:0.4rem 0.5rem">Normal</td><td style="text-align:center">&lt; 100</td><td style="text-align:center">&lt; 140</td></tr>
    <tr style="background:var(--bg)"><td style="padding:0.4rem 0.5rem">Prediabetes</td><td style="text-align:center">100–125</td><td style="text-align:center">140–199</td></tr>
    <tr><td style="padding:0.4rem 0.5rem">Diabetes</td><td style="text-align:center">≥ 126</td><td style="text-align:center">≥ 200</td></tr>
    <tr style="background:var(--bg)"><td style="padding:0.4rem 0.5rem">Hipoglucemia</td><td style="text-align:center">&lt; 70</td><td style="text-align:center">&lt; 70</td></tr>
  </table>
</div>

<script>
function calcGlucosa() {
  const val = parseFloat(document.getElementById('glu-val').value);
  const momento = document.getElementById('glu-momento').value;
  if (!val) return;

  let cat, color, consejo;

  if (val < 70) {
    cat = 'Hipoglucemia — nivel bajo'; color = '#3B82F6';
    consejo = 'Nivel bajo de azúcar. Si tienes síntomas (mareos, temblores), toma azúcar de absorción rápida y consulta a tu médico.';
  } else if (momento === 'ayunas') {
    if (val < 100) { cat = 'Normal ✓'; color = '#22C55E'; consejo = 'Tu nivel de glucosa en ayunas es normal.'; }
    else if (val < 126) { cat = 'Prediabetes'; color = '#EAB308'; consejo = 'Nivel elevado. Consulta con tu médico y revisa tu dieta y ejercicio.'; }
    else { cat = 'Posible diabetes'; color = '#EF4444'; consejo = 'Nivel muy elevado. Consulta con tu médico para confirmar con una segunda medición.'; }
  } else if (momento === 'postprandial') {
    if (val < 140) { cat = 'Normal ✓'; color = '#22C55E'; consejo = 'Tu nivel de glucosa 2 horas después de comer es normal.'; }
    else if (val < 200) { cat = 'Prediabetes'; color = '#EAB308'; consejo = 'Nivel elevado tras la comida. Consulta con tu médico.'; }
    else { cat = 'Posible diabetes'; color = '#EF4444'; consejo = 'Nivel muy elevado. Consulta con tu médico.'; }
  } else {
    if (val < 140) { cat = 'Probablemente normal ✓'; color = '#22C55E'; consejo = 'Nivel dentro del rango normal para una medición aleatoria.'; }
    else if (val < 200) { cat = 'Vigilar'; color = '#EAB308'; consejo = 'Nivel algo elevado. Confirma con una medición en ayunas.'; }
    else { cat = 'Posible diabetes'; color = '#EF4444'; consejo = 'Nivel muy elevado. Consulta con tu médico.'; }
  }

  document.getElementById('glu-res').innerHTML =
    `<span style="color:${color}">${val} mg/dL — ${cat}</span>
    <small>${consejo}</small>`;
}
</script>