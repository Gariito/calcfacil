<div class="row-2">
  <div>
    <label>Altura (cm)</label>
    <input type="number" id="pi-altura" placeholder="170" oninput="calcPesoIdeal()">
  </div>
  <div>
    <label>Sexo</label>
    <select id="pi-sexo" onchange="calcPesoIdeal()">
      <option value="h">Hombre</option>
      <option value="m">Mujer</option>
    </select>
  </div>
</div>

<div class="result-box" id="pi-res">Introduce tu altura</div>

<script>
function calcPesoIdeal() {
  const h = parseFloat(document.getElementById('pi-altura').value);
  const sexo = document.getElementById('pi-sexo').value;
  if (!h) return;
  const hm = h / 100;
  const hpulgadas = (h - 152.4) / 2.54;

  const lorentz = sexo==='h' ? h - 100 - (h-150)/4 : h - 100 - (h-150)/2;
  const devine = sexo==='h' ? 50 + 2.3 * hpulgadas : 45.5 + 2.3 * hpulgadas;
  const hamwi = sexo==='h' ? 48 + 2.7 * hpulgadas : 45.4 + 2.2 * hpulgadas;

  const imcMin = 18.5 * hm * hm;
  const imcMax = 24.9 * hm * hm;

  document.getElementById('pi-res').innerHTML =
    `Rango saludable: ${imcMin.toFixed(1)} – ${imcMax.toFixed(1)} kg
    <small>
    Lorentz: ${lorentz.toFixed(1)} kg · 
    Devine: ${devine.toFixed(1)} kg · 
    Hamwi: ${hamwi.toFixed(1)} kg
    </small>`;
}
</script>