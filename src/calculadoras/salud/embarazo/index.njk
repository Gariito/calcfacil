<label>Fecha de tu última regla (FUR)</label>
<input type="date" id="emb-fur" oninput="calcEmbarazo()" style="width:100%;padding:0.65rem 0.9rem;border:1px solid var(--border);border-radius:8px;font-size:1rem;background:var(--bg);margin-bottom:1rem">

<label>Duración de tu ciclo menstrual (días)</label>
<input type="number" id="emb-ciclo" placeholder="28" value="28" oninput="calcEmbarazo()">

<div class="result-box" id="emb-res">Introduce la fecha de tu última regla</div>

<div style="margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--border)">
  <h3 style="font-size:1rem;font-weight:600;margin-bottom:1rem">Trimestres del embarazo</h3>
  <p style="font-size:0.875rem;color:var(--muted);margin-bottom:0.5rem"><strong>Primer trimestre (semanas 1-12):</strong> Formación de órganos principales. Período más delicado.</p>
  <p style="font-size:0.875rem;color:var(--muted);margin-bottom:0.5rem"><strong>Segundo trimestre (semanas 13-26):</strong> El bebé crece rápidamente. Suelen desaparecer las náuseas.</p>
  <p style="font-size:0.875rem;color:var(--muted)"><strong>Tercer trimestre (semanas 27-40):</strong> Maduración final de órganos. El bebé gana peso.</p>
</div>

<script>
function calcEmbarazo() {
  const furVal = document.getElementById('emb-fur').value;
  const ciclo = parseInt(document.getElementById('emb-ciclo').value) || 28;
  if (!furVal) return;

  const fur = new Date(furVal);
  const hoy = new Date();
  const ajuste = ciclo - 28;
  const fpp = new Date(fur.getTime() + (280 + ajuste) * 86400000);

  const diffMs = hoy - fur;
  const diffDias = Math.floor(diffMs / 86400000);
  const semanas = Math.floor(diffDias / 7);
  const diasResto = diffDias % 7;

  if (diffDias < 0) {
    document.getElementById('emb-res').textContent = 'La fecha introducida es futura';
    return;
  }

  const meses = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
  const fppStr = `${fpp.getDate()} de ${meses[fpp.getMonth()]} de ${fpp.getFullYear()}`;

  let trimestre = semanas <= 12 ? 'Primer trimestre' : semanas <= 26 ? 'Segundo trimestre' : 'Tercer trimestre';

  document.getElementById('emb-res').innerHTML =
    `${semanas} semanas y ${diasResto} días
    <small>Fecha probable de parto: ${fppStr} · ${trimestre}</small>`;
}
</script>