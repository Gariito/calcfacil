<label>Modo de cálculo</label>
<select id="aho-modo" onchange="toggleAhorro()">
  <option value="tiempo">¿Cuánto tiempo necesito?</option>
  <option value="mensual">¿Cuánto debo ahorrar al mes?</option>
</select>

<label>Objetivo de ahorro (€)</label>
<input type="number" id="aho-obj" placeholder="10000" oninput="calcAhorro()">

<div id="aho-mensual-wrap">
  <label>Ahorro mensual (€)</label>
  <input type="number" id="aho-mes" placeholder="300" oninput="calcAhorro()">
</div>

<div id="aho-plazo-wrap" style="display:none">
  <label>Plazo deseado (meses)</label>
  <input type="number" id="aho-plazo" placeholder="24" oninput="calcAhorro()">
</div>

<label>Rentabilidad anual estimada (%)</label>
<input type="number" id="aho-rent" placeholder="2" value="0" oninput="calcAhorro()">

<label>Ahorro inicial (€)</label>
<input type="number" id="aho-inicial" placeholder="0" value="0" oninput="calcAhorro()">

<div class="result-box" id="aho-res">Introduce los datos</div>

<script>
function toggleAhorro() {
  const modo = document.getElementById('aho-modo').value;
  document.getElementById('aho-mensual-wrap').style.display = modo === 'tiempo' ? 'block' : 'none';
  document.getElementById('aho-plazo-wrap').style.display = modo === 'mensual' ? 'block' : 'none';
  calcAhorro();
}
function calcAhorro() {
  const modo = document.getElementById('aho-modo').value;
  const obj = parseFloat(document.getElementById('aho-obj').value);
  const rent = (parseFloat(document.getElementById('aho-rent').value) || 0) / 100 / 12;
  const inicial = parseFloat(document.getElementById('aho-inicial').value) || 0;
  if (!obj) return;

  if (modo === 'tiempo') {
    const mes = parseFloat(document.getElementById('aho-mes').value);
    if (!mes) return;
    let acum = inicial, meses = 0;
    while (acum < obj && meses < 1200) {
      acum = acum * (1 + rent) + mes;
      meses++;
    }
    const anos = Math.floor(meses / 12);
    const restoMeses = meses % 12;
    document.getElementById('aho-res').innerHTML =
      `${anos > 0 ? anos + ' años y ' : ''}${restoMeses} meses
      <small>Total ahorrado: ${acum.toFixed(0)} € · Intereses ganados: ${(acum - inicial - mes*meses).toFixed(0)} €</small>`;
  } else {
    const plazo = parseFloat(document.getElementById('aho-plazo').value);
    if (!plazo) return;
    let mes;
    if (rent === 0) {
      mes = (obj - inicial) / plazo;
    } else {
      mes = (obj - inicial * Math.pow(1+rent, plazo)) * rent / (Math.pow(1+rent, plazo) - 1);
    }
    document.getElementById('aho-res').innerHTML =
      `${mes.toFixed(2)} €/mes
      <small>Durante ${plazo} meses para llegar a ${obj.toLocaleString('es-ES')} €</small>`;
  }
}
</script>