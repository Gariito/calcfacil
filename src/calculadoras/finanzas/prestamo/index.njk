<label>Importe del préstamo (€)</label>
<input type="number" id="prest-imp" placeholder="10000" oninput="calcPrestamo()">

<div class="row-2">
  <div>
    <label>Tipo de interés anual (%)</label>
    <input type="number" id="prest-tasa" placeholder="8.5" oninput="calcPrestamo()">
  </div>
  <div>
    <label>Plazo (meses)</label>
    <input type="number" id="prest-plazo" placeholder="36" oninput="calcPrestamo()">
  </div>
</div>

<div class="result-box" id="prest-res">Introduce los datos del préstamo</div>

<script>
function calcPrestamo() {
  const imp = parseFloat(document.getElementById('prest-imp').value);
  const tasa = parseFloat(document.getElementById('prest-tasa').value);
  const plazo = parseFloat(document.getElementById('prest-plazo').value);
  if (!imp||!tasa||!plazo) return;
  const r = tasa / 100 / 12;
  const cuota = imp * r * Math.pow(1+r,plazo) / (Math.pow(1+r,plazo)-1);
  const total = cuota * plazo;
  const intereses = total - imp;
  document.getElementById('prest-res').innerHTML =
    `${cuota.toFixed(2)} €/mes
    <small>Total a pagar: ${total.toFixed(2)} € · Intereses: ${intereses.toFixed(2)} €</small>`;
}
</script>