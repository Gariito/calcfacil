<label>Base reguladora mensual estimada (€)</label>
<input type="number" id="pen-base" placeholder="1800" oninput="calcPension()">
<p style="font-size:0.8rem;color:var(--muted);margin-top:-0.5rem;margin-bottom:1rem">Media de tus últimas cotizaciones mensuales</p>

<label>Años cotizados a la Seguridad Social</label>
<input type="number" id="pen-anos" placeholder="30" oninput="calcPension()">

<label>Edad de jubilación</label>
<select id="pen-edad" onchange="calcPension()">
  <option value="1">65 años (ordinaria con 37,5 años cotizados)</option>
  <option value="1">66 años y 6 meses (ordinaria con menos años)</option>
  <option value="0.93">63 años (anticipada voluntaria)</option>
  <option value="0.96">64 años (anticipada voluntaria)</option>
</select>

<div class="result-box" id="pen-res">Introduce tus datos</div>

<div style="margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--border)">
  <h3 style="font-size:1rem;font-weight:600;margin-bottom:1rem">Porcentaje según años cotizados</h3>
  <table style="width:100%;font-size:0.825rem;border-collapse:collapse">
    <tr style="background:var(--bg)">
      <th style="padding:0.5rem;text-align:left;border-bottom:1px solid var(--border)">Años cotizados</th>
      <th style="padding:0.5rem;text-align:right;border-bottom:1px solid var(--border)">% de la base</th>
    </tr>
    <tr><td style="padding:0.4rem 0.5rem">15 años</td><td style="text-align:right">50%</td></tr>
    <tr style="background:var(--bg)"><td style="padding:0.4rem 0.5rem">20 años</td><td style="text-align:right">65%</td></tr>
    <tr><td style="padding:0.4rem 0.5rem">25 años</td><td style="text-align:right">78,5%</td></tr>
    <tr style="background:var(--bg)"><td style="padding:0.4rem 0.5rem">30 años</td><td style="text-align:right">88,5%</td></tr>
    <tr><td style="padding:0.4rem 0.5rem">35 años</td><td style="text-align:right">97%</td></tr>
    <tr style="background:var(--bg)"><td style="padding:0.4rem 0.5rem">37+ años</td><td style="text-align:right">100%</td></tr>
  </table>
</div>

<script>
function calcPension() {
  const base = parseFloat(document.getElementById('pen-base').value);
  const anos = parseFloat(document.getElementById('pen-anos').value);
  const coefEdad = parseFloat(document.getElementById('pen-edad').value);
  if (!base || !anos) return;

  let pct;
  if (anos < 15) { document.getElementById('pen-res').textContent = 'Se necesitan mínimo 15 años cotizados'; return; }
  else if (anos < 25) pct = 0.50 + (anos - 15) * 0.019;
  else if (anos < 37) pct = 0.69 + (anos - 25) * 0.023;
  else pct = 1.0;

  pct = Math.min(pct, 1.0);
  const pension = base * pct * coefEdad;
  const anual = pension * 14;

  document.getElementById('pen-res').innerHTML =
    `Pensión estimada: ${pension.toFixed(2)} €/mes
    <small>
    ${(pct * 100).toFixed(1)}% de la base reguladora · 
    14 pagas: ${anual.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, '.')} €/año
    </small>`;
}
</script>