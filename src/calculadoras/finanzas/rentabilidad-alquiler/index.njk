<label>Precio de compra del inmueble (€)</label>
<input type="number" id="alq-precio" placeholder="180000" oninput="calcAlquiler()">

<label>Gastos de compra — notaría, impuestos, reforma (€)</label>
<input type="number" id="alq-gastos" placeholder="18000" oninput="calcAlquiler()">

<label>Alquiler mensual (€)</label>
<input type="number" id="alq-mes" placeholder="800" oninput="calcAlquiler()">

<label>Gastos anuales — IBI, comunidad, seguro (€)</label>
<input type="number" id="alq-gast-an" placeholder="1500" oninput="calcAlquiler()">

<label>Meses al año sin inquilino (vacíos)</label>
<input type="number" id="alq-vacios" placeholder="1" value="1" oninput="calcAlquiler()">

<div class="result-box" id="alq-res">Introduce los datos del inmueble</div>

<script>
function calcAlquiler() {
  const precio = parseFloat(document.getElementById('alq-precio').value);
  const gastos = parseFloat(document.getElementById('alq-gastos').value) || 0;
  const mes = parseFloat(document.getElementById('alq-mes').value);
  const gastosAn = parseFloat(document.getElementById('alq-gast-an').value) || 0;
  const vacios = parseFloat(document.getElementById('alq-vacios').value) || 0;
  if (!precio || !mes) return;

  const inversion = precio + gastos;
  const ingresosAn = mes * (12 - vacios);
  const rentBruta = (mes * 12 / precio) * 100;
  const rentNeta = ((ingresosAn - gastosAn) / inversion) * 100;

  document.getElementById('alq-res').innerHTML =
    `Rentabilidad bruta: ${rentBruta.toFixed(2)}%
    <small>Rentabilidad neta: ${rentNeta.toFixed(2)}% · Ingresos anuales: ${ingresosAn.toFixed(0)} € · Inversión total: ${inversion.toLocaleString('es-ES')} €</small>`;
}
</script>