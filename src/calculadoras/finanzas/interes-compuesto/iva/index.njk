<label>Importe (€)</label>
<input type="number" id="iva-val" placeholder="100" oninput="calcIVA()">

<label>Tipo de IVA</label>
<select id="iva-pct" onchange="calcIVA()">
  <option value="21">21% — IVA general</option>
  <option value="10">10% — IVA reducido</option>
  <option value="4">4% — IVA superreducido</option>
  <option value="0">0% — Exento de IVA</option>
</select>

<label>El importe introducido es…</label>
<select id="iva-tipo" onchange="calcIVA()">
  <option value="sin">Sin IVA (base imponible) → calcular precio final</option>
  <option value="con">Con IVA (precio final) → calcular base imponible</option>
</select>

<div class="result-box" id="iva-res">Introduce un importe</div>