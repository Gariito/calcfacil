<div class="row-2">
  <div>
    <label>Fecha del examen</label>
    <input type="date" id="est-fecha" oninput="calcEstudio()" style="width:100%;padding:0.65rem 0.9rem;border:1px solid var(--border);border-radius:8px;font-size:1rem;background:var(--bg);margin-bottom:1rem">
  </div>
  <div>
    <label>Número de temas</label>
    <input type="number" id="est-temas" placeholder="10" oninput="calcEstudio()">
  </div>
</div>

<label>Horas estimadas por tema</label>
<input type="number" id="est-hpt" placeholder="3" oninput="calcEstudio()">

<label>Horas ya estudiadas</label>
<input type="number" id="est-ya" placeholder="0" value="0" oninput="calcEstudio()">

<label>Días de descanso a la semana</label>
<select id="est-desc" onchange="calcEstudio()">
  <option value="0">Ninguno (estudio todos los días)</option>
  <option value="1">1 día de descanso</option>
  <option value="2" selected>2 días de descanso (fin de semana)</option>
</select>

<div class="result-box" id="est-res">Introduce los datos del examen</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const hoy = new Date();
  hoy.setDate(hoy.getDate() + 14);
  document.getElementById('est-fecha').value = hoy.toISOString().split('T')[0];
  calcEstudio();
});

function calcEstudio() {
  const fecha = document.getElementById('est-fecha').value;
  const temas = parseFloat(document.getElementById('est-temas').value);
  const hpt = parseFloat(document.getElementById('est-hpt').value);
  const ya = parseFloat(document.getElementById('est-ya').value) || 0;
  const desc = parseInt(document.getElementById('est-desc').value);
  if (!fecha || !temas || !hpt) return;

  const hoy = new Date();
  const examen = new Date(fecha);
  const diasTotal = Math.max(0, Math.round((examen - hoy) / 86400000));
  const diasEstudio = Math.max(1, Math.round(diasTotal * (7 - desc) / 7));

  const horasTotal = temas * hpt;
  const horasRestantes = Math.max(0, horasTotal - ya);
  const horasDia = horasRestantes / diasEstudio;
  const pomodoros = Math.ceil(horasDia * 60 / 25);

  document.getElementById('est-res').innerHTML =
    `${horasDia.toFixed(1)} horas al día
    <small>
    ${diasEstudio} días de estudio · 
    ${horasRestantes.toFixed(0)}h restantes · 
    ~${pomodoros} pomodoros/día
    </small>`;
}
</script>