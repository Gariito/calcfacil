---
layout: base.njk
title: Calculadoras de educación gratuitas
description: Calculadoras educativas gratuitas. Nota media ponderada, nota de selectividad EBAU y horas de estudio.
keywords: calculadora nota media, selectividad ebau, horas estudio examen, planificador estudio
---

<div class="cat-page">
  <div class="container">
    <div class="cat-header">
      <h1>📚 Calculadoras de educación</h1>
      <p>Calcula notas, medias y planifica tu estudio al instante.</p>
    </div>

    <div class="search-wrap">
      <span class="search-icon">🔍</span>
      <input type="text" class="search-input" id="cat-search"
        placeholder="Buscar... nota media, selectividad, estudio..."
        oninput="searchCat(this.value)" autocomplete="off">
      <div class="search-count" id="cat-count"></div>
    </div>

    <div class="search-empty" id="cat-empty">
      <div class="empty-icon">🔍</div>
      <p>No se encontraron calculadoras para "<span id="cat-empty-term"></span>"</p>
    </div>

    <div class="calc-cards" id="cat-grid">
      <a class="calc-card-link" href="/calculadoras/educacion/nota-media/">
        <span class="icon">📝</span>
        <div><h2>Calculadora de nota media</h2><p>Calcula tu nota media ponderada a partir de tus calificaciones y créditos.</p></div>
      </a>
      <a class="calc-card-link" href="/calculadoras/educacion/nota-selectividad/">
        <span class="icon">🎓</span>
        <div><h2>Nota de selectividad (EBAU)</h2><p>Calcula tu nota de acceso a la universidad con la fórmula oficial.</p></div>
      </a>
      <a class="calc-card-link" href="/calculadoras/educacion/horas-estudio/">
        <span class="icon">📖</span>
        <div><h2>Calculadora de horas de estudio</h2><p>Calcula cuántas horas al día necesitas estudiar para tu examen.</p></div>
      </a>
    </div>
  </div>
</div>

<script>
function searchCat(q) {
  const term = q.toLowerCase().trim();
  const cards = document.querySelectorAll('#cat-grid .calc-card-link');
  const empty = document.getElementById('cat-empty');
  const count = document.getElementById('cat-count');
  let visible = 0;
  cards.forEach(card => {
    const text = card.textContent.toLowerCase();
    if (!term || text.includes(term)) { card.classList.remove('hidden'); visible++; }
    else card.classList.add('hidden');
  });
  if (term) {
    count.textContent = visible + ' calculadora' + (visible !== 1 ? 's' : '') + ' encontrada' + (visible !== 1 ? 's' : '');
    document.getElementById('cat-empty-term').textContent = q;
    empty.style.display = visible === 0 ? 'block' : 'none';
  } else { count.textContent = ''; empty.style.display = 'none'; }
}
</script>