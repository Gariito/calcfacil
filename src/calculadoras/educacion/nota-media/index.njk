<div id="nm-asignaturas">
  <div class="row-2 nm-fila">
    <div><label>Nota (0-10)</label><input type="number" class="nm-nota" placeholder="7.5" oninput="calcMedia()"></div>
    <div><label>Créditos / Peso</label><input type="number" class="nm-cred" placeholder="6" oninput="calcMedia()"></div>
  </div>
  <div class="row-2 nm-fila">
    <div><input type="number" class="nm-nota" placeholder="8.0" oninput="calcMedia()"></div>
    <div><input type="number" class="nm-cred" placeholder="6" oninput="calcMedia()"></div>
  </div>
  <div class="row-2 nm-fila">
    <div><input type="number" class="nm-nota" placeholder="6.5" oninput="calcMedia()"></div>
    <div><input type="number" class="nm-cred" placeholder="6" oninput="calcMedia()"></div>
  </div>
</div>

<button onclick="addFila()" style="background:none;border:1px solid var(--border);border-radius:8px;padding:0.5rem 1rem;cursor:pointer;margin-bottom:1rem;font-size:0.875rem;color:var(--accent)">+ Añadir asignatura</button>

<div class="result-box" id="nm-res">Introduce tus notas</div>

<script>
function addFila() {
  const div = document.createElement('div');
  div.className = 'row-2 nm-fila';
  div.innerHTML = '<div><input type="number" class="nm-nota" placeholder="7.0" oninput="calcMedia()" style="width:100%;padding:0.65rem 0.9rem;border:1px solid var(--border);border-radius:8px;font-size:1rem;background:var(--bg);margin-bottom:1rem"></div><div><input type="number" class="nm-cred" placeholder="6" oninput="calcMedia()" style="width:100%;padding:0.65rem 0.9rem;border:1px solid var(--border);border-radius:8px;font-size:1rem;background:var(--bg);margin-bottom:1rem"></div>';
  document.getElementById('nm-asignaturas').appendChild(div);
}
function calcMedia() {
  const notas = [...document.querySelectorAll('.nm-nota')].map(i => parseFloat(i.value));
  const creds = [...document.querySelectorAll('.nm-cred')].map(i => parseFloat(i.value));
  let sumProd = 0, sumCred = 0, count = 0;
  notas.forEach((n, i) => {
    if (!isNaN(n) && !isNaN(creds[i])) { sumProd += n * creds[i]; sumCred += creds[i]; count++; }
    else if (!isNaN(n)) { sumProd += n; sumCred += 1; count++; }
  });
  if (count === 0) return;
  const media = sumProd / sumCred;
  document.getElementById('nm-res').innerHTML =
    `Media ponderada: ${media.toFixed(4)}<small>${count} asignaturas · ${sumCred} créditos totales</small>`;
}
</script>