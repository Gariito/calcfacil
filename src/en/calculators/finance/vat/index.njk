<script>
function calcVAT() {
  const v = parseFloat(document.getElementById('vat-val').value);
  const rate = parseFloat(document.getElementById('vat-rate').value);
  const tipo = document.getElementById('vat-tipo').value;
  if (isNaN(v)) return;
  if (tipo === 'sin') {
    const vat = v * rate / 100;
    document.getElementById('vat-res').innerHTML =
      `Price with VAT: ${(v + vat).toFixed(2)}<small>Net: ${v.toFixed(2)} · VAT (${rate}%): ${vat.toFixed(2)}</small>`;
  } else {
    const net = v / (1 + rate / 100);
    const vat = v - net;
    document.getElementById('vat-res').innerHTML =
      `Net price: ${net.toFixed(2)}<small>VAT (${rate}%): ${vat.toFixed(2)} · Gross: ${v.toFixed(2)}</small>`;
  }
}
</script>