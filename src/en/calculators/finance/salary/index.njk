<script>
function calcSN() {
  const bruto = parseFloat(document.getElementById('sn-bruto').value);
  const sit = parseInt(document.getElementById('sn-sit').value);
  if (!bruto) return;
  const ss = bruto * 0.0635;
  const minPersonal = 5550;
  const minFamiliar = [0,0,2400,4800,8000][sit]||0;
  const minConyuge = sit===1?2550:0;
  const baseL = Math.max(0, bruto-ss-minPersonal-minFamiliar-minConyuge);
  const tramos = [[12450,0.19],[20200,0.24],[35200,0.30],[60000,0.37],[300000,0.45],[Infinity,0.47]];
  let irpf=0, resto=baseL, anterior=0;
  for (const [hasta,tipo] of tramos) {
    if (resto<=0) break;
    const tramo=Math.min(resto,hasta-anterior);
    irpf+=tramo*tipo; resto-=tramo; anterior=hasta;
  }
  const neto=bruto-ss-irpf;
  document.getElementById('sn-res').innerHTML =
    `Net annual: ${neto.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g,'.')} €<small>Monthly: ${(neto/12).toFixed(0)} € · Tax: ${irpf.toFixed(0)} € · SS: ${ss.toFixed(0)} €</small>`;
}
</script>