<script>
function calcHipo() {
  const m = parseFloat(document.getElementById('hip-monto').value);
  const t = parseFloat(document.getElementById('hip-tasa').value);
  const a = parseFloat(document.getElementById('hip-anos').value);
  if (!m||!t||!a) return;
  const r = t/100/12, n = a*12;
  const cuota = m*r*Math.pow(1+r,n)/(Math.pow(1+r,n)-1);
  const total = cuota*n;
  document.getElementById('hip-res').innerHTML =
    `${cuota.toFixed(2)} €/month<small>Total paid: ${total.toFixed(2)} € · Interest: ${(total-m).toFixed(2)} €</small>`;
}
</script>