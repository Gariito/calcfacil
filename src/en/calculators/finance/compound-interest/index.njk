</div>

<script>
function calcIC() {
  const c = parseFloat(document.getElementById('ic-capital').value);
  const tasa = parseFloat(document.getElementById('ic-tasa').value);
  const anos = parseFloat(document.getElementById('ic-anos').value);
  const aport = parseFloat(document.getElementById('ic-aport').value) || 0;
  if (!c||!tasa||!anos) return;
  const r = tasa/100/12, n = anos*12;
  const futuro = c*Math.pow(1+r,n) + aport*(Math.pow(1+r,n)-1)/r;
  const inv = c + aport*n;
  document.getElementById('ic-res').innerHTML =
    `${futuro.toFixed(2)} €<small>Invested: ${inv.toFixed(2)} € · Earnings: ${(futuro-inv).toFixed(2)} €</small>`;
}
</script>