<script>
function calcPct() {
  const p = parseFloat(document.getElementById('pct-pct').value);
  const v = parseFloat(document.getElementById('pct-val').value);
  if (isNaN(p)||isNaN(v)) return;
  const r = v*p/100;
  document.getElementById('pct-res').innerHTML =
    `${parseFloat(r.toFixed(6)).toLocaleString()}<small>${p}% of ${v} = ${r.toFixed(4)}</small>`;
}
function calcPct2() {
  const x = parseFloat(document.getElementById('pct2-x').value);
  const y = parseFloat(document.getElementById('pct2-y').value);
  if (isNaN(x)||isNaN(y)||y===0) return;
  document.getElementById('pct2-res').innerHTML =
    `${(x/y*100).toFixed(4)}%<small>${x} is ${(x/y*100).toFixed(2)}% of ${y}</small>`;
}
</script>