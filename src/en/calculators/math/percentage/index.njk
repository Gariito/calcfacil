      <div class="calc-main">
        <h1>% Percentage Calculator</h1>
        <p class="calc-intro">Calculate any percentage instantly — find X% of a number or what percentage X is of Y.</p>

        <div class="card">
          <p style="font-weight:600;margin-bottom:1rem">What is X% of Y?</p>
          <div class="row-2">
            <div><label>Percentage (%)</label><input type="number" id="pct-pct" placeholder="15" oninput="calcPct()"></div>
            <div><label>Of number</label><input type="number" id="pct-val" placeholder="200" oninput="calcPct()"></div>
          </div>
          <div class="result-box" id="pct-res">Enter the values</div>

          <div style="margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid var(--border)">
            <p style="font-weight:600;margin-bottom:1rem">X is what % of Y?</p>
            <div class="row-2">
              <div><label>X (part)</label><input type="number" id="pct2-x" placeholder="30" oninput="calcPct2()"></div>
              <div><label>Y (total)</label><input type="number" id="pct2-y" placeholder="200" oninput="calcPct2()"></div>
            </div>
