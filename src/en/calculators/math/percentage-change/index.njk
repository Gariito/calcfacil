<script>
function calcPC(){
  const orig=parseFloat(document.getElementById('pc-orig').value);
  const newV=parseFloat(document.getElementById('pc-new').value);
  if(isNaN(orig)||isNaN(newV))return;
  const change=(newV-orig)/Math.abs(orig)*100;
  const diff=newV-orig;
  const dir=change>=0?'▲ increase':'▼ decrease';
  const color=change>=0?'#22C55E':'#EF4444';
  document.getElementById('pc-res').innerHTML=
    `<span style="color:${color}">${Math.abs(change).toFixed(4)}% ${dir}</span>
    <small>From ${orig} to ${newV} · Difference: ${diff>=0?'+':''}${diff.toFixed(4)}</small>`;
}
</script>