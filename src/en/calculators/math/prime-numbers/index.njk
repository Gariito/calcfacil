<script>
function isPrime(n){if(n<2)return false;if(n===2)return true;if(n%2===0)return false;for(let i=3;i<=Math.sqrt(n);i+=2){if(n%i===0)return false;}return true;}
function factorise(n){const f=[];let d=2;while(d*d<=n){while(n%d===0){f.push(d);n=Math.floor(n/d);}d++;}if(n>1)f.push(n);return f;}
function calcPrime(){
  const n=parseInt(document.getElementById('pr-num').value);
  if(isNaN(n)||n<1)return;
  const prime=isPrime(n);
  const factors=factorise(n);
  let next=n+1; while(!isPrime(next))next++;
  let prev=n-1; while(prev>1&&!isPrime(prev))prev--;
  if(prime){
    document.getElementById('pr-res').innerHTML=
      `${n} IS a prime number ✓
      <small>Previous prime: ${prev>1?prev:'—'} · Next prime: ${next}</small>`;
  } else {
    document.getElementById('pr-res').innerHTML=
      `${n} is NOT prime
      <small>Prime factors: ${factors.join(' × ')} · Previous prime: ${prev>1?prev:'—'} · Next prime: ${next}</small>`;
  }
}
</script>