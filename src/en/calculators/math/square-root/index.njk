<script>
function toggleSR() {
  document.getElementById('sr-exp-wrap').style.display =
    document.getElementById('sr-op').value === 'pow' ? 'block' : 'none';
  calcSR();
}
function calcSR() {
  const n = parseFloat(document.getElementById('sr-num').value);
  const op = document.getElementById('sr-op').value;
  if (isNaN(n)) return;
  let r, label;
  if (op==='sqrt') { r=Math.sqrt(n); label=`√${n}`; }
  else if (op==='cbrt') { r=Math.cbrt(n); label=`∛${n}`; }
  else if (op==='sq') { r=n*n; label=`${n}²`; }
  else if (op==='cb') { r=n*n*n; label=`${n}³`; }
  else {
    const exp = parseFloat(document.getElementById('sr-exp').value);
    if (isNaN(exp)) return;
    r=Math.pow(n,exp); label=`${n}^${exp}`;
  }
  document.getElementById('sr-res').innerHTML =
    isNaN(r) ? 'Cannot calculate for this input' :
    `${label} = ${parseFloat(r.toFixed(10)).toLocaleString('en-GB',{maximumFractionDigits:8})}`;
}
</script>