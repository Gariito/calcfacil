<script>
function gcdF(a,b){return b===0?Math.abs(a):gcdF(b,a%b);}
function updateSymbol(){
  const syms={add:'+',sub:'−',mul:'×',div:'÷'};
  document.getElementById('frac-sym').textContent=syms[document.getElementById('frac-op').value];
  calcFrac();
}
function calcFrac(){
  const a=parseInt(document.getElementById('frac-a').value);
  const b=parseInt(document.getElementById('frac-b').value);
  const c=parseInt(document.getElementById('frac-c').value);
  const d=parseInt(document.getElementById('frac-d').value);
  const op=document.getElementById('frac-op').value;
  if(isNaN(a)||isNaN(b)||isNaN(c)||isNaN(d)||b===0||d===0)return;
  let rn,rd;
  if(op==='add'){rn=a*d+c*b;rd=b*d;}
  else if(op==='sub'){rn=a*d-c*b;rd=b*d;}
  else if(op==='mul'){rn=a*c;rd=b*d;}
  else{rn=a*d;rd=b*c;}
  if(rd===0){document.getElementById('frac-res').textContent='Division by zero';return;}
  if(rd<0){rn=-rn;rd=-rd;}
  const g=gcdF(Math.abs(rn),Math.abs(rd));
  const sn=rn/g,sd=rd/g;
  const decimal=(rn/rd);
  document.getElementById('frac-res').innerHTML=sd===1
    ?`${sn}<small>Result simplified · Decimal: ${decimal.toFixed(6).replace(/\.?0+$/,'')}</small>`
    :`${sn}/${sd}<small>Simplified fraction · Decimal: ${decimal.toFixed(6).replace(/\.?0+$/,'')}</small>`;
}
</script>