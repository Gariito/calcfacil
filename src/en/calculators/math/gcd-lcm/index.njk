<script>
function gcd(a,b){return b===0?a:gcd(b,a%b);}
function lcm(a,b){return(a*b)/gcd(a,b);}
function calcGL(){
  const raw=document.getElementById('gl-nums').value;
  const nums=raw.split(/[\s,;]+/).map(Number).filter(n=>Number.isInteger(n)&&n>0);
  if(nums.length<2)return;
  const gcdVal=nums.reduce(gcd);
  const lcmVal=nums.reduce(lcm);
  const divisors=[];
  for(let i=1;i<=gcdVal;i++){if(gcdVal%i===0)divisors.push(i);}
  document.getElementById('gl-res').innerHTML=
    `GCD: ${gcdVal} · LCM: ${lcmVal.toLocaleString('en-GB')}
    <small>Divisors of GCD: ${divisors.join(', ')}</small>`;
}
</script>