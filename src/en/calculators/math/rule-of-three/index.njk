<script>
function calcRT() {
  const a = parseFloat(document.getElementById('rt-a').value);
  const b = parseFloat(document.getElementById('rt-b').value);
  const c = parseFloat(document.getElementById('rt-c').value);
  const tipo = document.getElementById('rt-tipo').value;
  if (!a||!b||!c) return;
  const x = tipo === 'directa' ? (b*c)/a : (a*b)/c;
  const xFmt = parseFloat(x.toFixed(6)).toLocaleString('en-GB', {maximumFractionDigits:4});
  document.getElementById('rt-x').textContent = xFmt;
  document.getElementById('rt-res').innerHTML =
    `X = ${xFmt}<small>${tipo === 'directa' ? 'Direct' : 'Inverse'} proportion · ${a} → ${b} · ${c} → ${xFmt}</small>`;
}
</script>