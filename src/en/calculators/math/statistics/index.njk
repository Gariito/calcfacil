<script>
function calcStat(){
  const raw=document.getElementById('stat-nums').value;
  const nums=raw.split(/[\s,;]+/).map(Number).filter(n=>!isNaN(n)&&raw.trim()!=='');
  if(nums.length<2)return;
  const sorted=[...nums].sort((a,b)=>a-b);
  const n=nums.length;
  const mean=nums.reduce((a,b)=>a+b,0)/n;
  const median=n%2===0?(sorted[n/2-1]+sorted[n/2])/2:sorted[Math.floor(n/2)];
  const freq={};
  nums.forEach(v=>freq[v]=(freq[v]||0)+1);
  const maxFreq=Math.max(...Object.values(freq));
  const mode=Object.keys(freq).filter(k=>freq[k]===maxFreq).join(', ');
  const range=sorted[n-1]-sorted[0];
  const variance=nums.reduce((a,b)=>a+Math.pow(b-mean,2),0)/n;
  const stdDev=Math.sqrt(variance);
  const sum=nums.reduce((a,b)=>a+b,0);

  document.getElementById('stat-res').innerHTML=
    `Mean: ${mean.toFixed(4)}<small>Median: ${median} · Mode: ${mode} · n: ${n}</small>`;

  document.getElementById('stat-grid').innerHTML=`
    <div style="background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:0.75rem;text-align:center">
      <div style="font-size:1.3rem;font-weight:700;color:var(--accent)">${mean.toFixed(4)}</div>
      <div style="font-size:0.8rem;color:var(--muted)">Mean</div>
    </div>
    <div style="background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:0.75rem;text-align:center">
      <div style="font-size:1.3rem;font-weight:700;color:var(--accent)">${median}</div>
      <div style="font-size:0.8rem;color:var(--muted)">Median</div>
    </div>
    <div style="background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:0.75rem;text-align:center">
      <div style="font-size:1.3rem;font-weight:700;color:var(--accent)">${mode}</div>
      <div style="font-size:0.8rem;color:var(--muted)">Mode</div>
    </div>
    <div style="background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:0.75rem;text-align:center">
      <div style="font-size:1.3rem;font-weight:700;color:var(--accent)">${range}</div>
      <div style="font-size:0.8rem;color:var(--muted)">Range</div>
    </div>
    <div style="background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:0.75rem;text-align:center">
      <div style="font-size:1.3rem;font-weight:700;color:var(--accent)">${stdDev.toFixed(4)}</div>
      <div style="font-size:0.8rem;color:var(--muted)">Std Deviation</div>
    </div>
    <div style="background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:0.75rem;text-align:center">
      <div style="font-size:1.3rem;font-weight:700;color:var(--accent)">${sum.toLocaleString('en-GB')}</div>
      <div style="font-size:0.8rem;color:var(--muted)">Sum</div>
    </div>`;
}
</script>