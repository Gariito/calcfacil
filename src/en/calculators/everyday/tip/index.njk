<script>
function setTip(v) {
  document.getElementById('tip-pct').value = v;
  document.getElementById('tip-pct-val').textContent = v + '%';
  calcTip();
}
function calcTip() {
  const total = parseFloat(document.getElementById('tip-total').value);
  const pct = parseFloat(document.getElementById('tip-pct').value);
  const pers = parseInt(document.getElementById('tip-pers').value) || 1;
  if (isNaN(total)) return;
  const tip = total * pct / 100;
  const grand = total + tip;
  const perPerson = grand / pers;
  document.getElementById('tip-res').innerHTML =
    `Tip: ${tip.toFixed(2)} · Total: ${grand.toFixed(2)}
    <small>${pers > 1 ? `Per person: ${perPerson.toFixed(2)}` : `${pct}% tip on ${total.toFixed(2)}`}</small>`;
}
</script>