      <div class="calc-main">
        <h1>🍽️ Tip Calculator</h1>
        <p class="calc-intro">Calculate the tip and split the bill between any number of people instantly.</p>

        <div class="card">
          <label>Total bill amount</label>
          <input type="number" id="tip-total" placeholder="85.00" oninput="calcTip()">

          <label>Tip percentage</label>
          <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1rem">
            <input type="range" min="0" max="30" value="15" id="tip-pct"
              oninput="document.getElementById('tip-pct-val').textContent=this.value+'%'; calcTip()"
              style="flex:1;margin-bottom:0">
            <span id="tip-pct-val" style="font-weight:600;min-width:40px;font-size:1.1rem">15%</span>
          </div>

          <label>Number of people</label>
          <input type="number" id="tip-pers" placeholder="2" value="1" oninput="calcTip()">

          <div class="result-box" id="tip-res">Enter the bill amount</div>
        </div>

        <div style="margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid var(--border)">
          <p style="font-size:0.875rem;font-weight:600;margin-bottom:0.75rem">Common tip amounts</p>
          <div style="display:flex;flex-wrap:wrap;gap:0.5rem">
            <button onclick="setTip(10)" style="padding:0.35rem 0.75rem;border:1px solid var(--border);border-radius:6px;background:var(--bg);cursor:pointer;font-size:0.825rem">10%</button>
            <button onclick="setTip(15)" style="padding:0.35rem 0.75rem;border:1px solid var(--border);border-radius:6px;background:var(--bg);cursor:pointer;font-size:0.825rem">15%</button>
            <button onclick="setTip(18)" style="padding:0.35rem 0.75rem;border:1px solid var(--border);border-radius:6px;background:var(--bg);cursor:pointer;font-size:0.825rem">18%</button>
            <button onclick="setTip(20)" style="padding:0.35rem 0.75rem;border:1px solid var(--border);border-radius:6px;background:var(--bg);cursor:pointer;font-size:0.825rem">20%</button>
            <button onclick="setTip(25)" style="padding:0.35rem 0.75rem;border:1px solid var(--border);border-radius:6px;background:var(--bg);cursor:pointer;font-size:0.825rem">25%</button>
          </div>
        </div>
