</div>

<script>
function calcP1() {
  const p = parseFloat(document.getElementById('p1-pct').value);
  const v = parseFloat(document.getElementById('p1-val').value);
  if (isNaN(p)||isNaN(v)) return;
  const r = v*p/100;
  document.getElementById('p1-res').innerHTML =
    `${p}% of ${v} = ${parseFloat(r.toFixed(6)).toLocaleString('en-GB',{maximumFractionDigits:4})}`;
}
function calcP2() {
  const x = parseFloat(document.getElementById('p2-x').value);
  const y = parseFloat(document.getElementById('p2-y').value);
  if (isNaN(x)||isNaN(y)||y===0) return;
  document.getElementById('p2-res').innerHTML =
    `${x} is ${(x/y*100).toFixed(4)}% of ${y}`;
}
function calcP3() {
  const x = parseFloat(document.getElementById('p3-x').value);
  const y = parseFloat(document.getElementById('p3-y').value);
  if (isNaN(x)||isNaN(y)||x===0) return;
  const change = (y-x)/Math.abs(x)*100;
  const dir = change >= 0 ? '▲ increase' : '▼ decrease';
  const color = change >= 0 ? '#22C55E' : '#EF4444';
  document.getElementById('p3-res').innerHTML =
    `<span style="color:${color}">${Math.abs(change).toFixed(4)}% ${dir}</span>
    <small>From ${x} to ${y} · Difference: ${(y-x) >= 0?'+':''}${(y-x).toFixed(4)}</small>`;
}
</script>