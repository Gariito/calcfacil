<script>
document.addEventListener('DOMContentLoaded', () => {
  const today = new Date().toISOString().split('T')[0];
  document.getElementById('dc-start').value = today;
});

function setPreset(p) {
  const today = new Date();
  const start = today.toISOString().split('T')[0];
  let end;
  if (p === 'christmas') {
    end = new Date(today.getFullYear(), 11, 25);
    if (end < today) end = new Date(today.getFullYear()+1, 11, 25);
  } else if (p === 'newyear') {
    end = new Date(today.getFullYear()+1, 0, 1);
  } else if (p === '100days') {
    end = new Date(today.getTime() + 100*86400000);
  } else {
    end = new Date(today.getFullYear()+1, today.getMonth(), today.getDate());
  }
  document.getElementById('dc-start').value = start;
  document.getElementById('dc-end').value = end.toISOString().split('T')[0];
  calcDate();
}

function calcDate() {
  const s = document.getElementById('dc-start').value;
  const e = document.getElementById('dc-end').value;
  const work = document.getElementById('dc-work').value;
  if (!s || !e) return;
  const d1 = new Date(s), d2 = new Date(e);
  const diff = Math.round((d2-d1)/86400000);
  if (diff < 0) { document.getElementById('dc-res').textContent = 'End date is before start date'; return; }
  let workDays = 0;
  if (work === 'yes') {
    let cur = new Date(d1);
    while (cur < d2) {
      const dow = cur.getDay();
      if (dow !== 0 && dow !== 6) workDays++;
      cur.setDate(cur.getDate()+1);
    }
  }
  const weeks = Math.floor(diff/7), rem = diff%7;
  const months = Math.floor(diff/30.44);
  document.getElementById('dc-res').innerHTML =
    `${diff} days
    <small>${weeks} weeks and ${rem} days · ~${months} months${work==='yes'?' · '+workDays+' working days':''}</small>`;
}
</script>