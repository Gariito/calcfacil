              <label>Start date</label>
              <input type="date" id="dc-start" oninput="calcDate()" style="width:100%;padding:0.65rem 0.9rem;border:1px solid var(--border);border-radius:8px;font-size:1rem;background:var(--bg);margin-bottom:1rem">
            </div>
