              <label>End date</label>
              <input type="date" id="dc-end" oninput="calcDate()" style="width:100%;padding:0.65rem 0.9rem;border:1px solid var(--border);border-radius:8px;font-size:1rem;background:var(--bg);margin-bottom:1rem">
            </div>
          </div>

          <label>Count only working days (Mon–Fri)?</label>
          <select id="dc-work" onchange="calcDate()">
            <option value="no">No — count all days</option>
            <option value="yes">Yes — working days only</option>
          </select>

          <div class="result-box" id="dc-res">Enter the two dates</div>
