<script>
let sciState = { expr:'', display:'0', ans:0, mode:'deg', newN:true };
function setMode(m) {
  sciState.mode = m;
  document.getElementById('btn-deg').classList.toggle('active', m==='deg');
  document.getElementById('btn-rad').classList.toggle('active', m==='rad');
}
function sciDisp() {
  document.getElementById('sci-val').textContent = sciState.display;
  document.getElementById('sci-expr').textContent = sciState.expr;
  document.getElementById('sci-ans').textContent = sciState.ans;
}
function sciNum(d) {
  if (sciState.newN) { sciState.display = d; sciState.newN = false; }
  else sciState.display = sciState.display === '0' ? d : sciState.display + d;
  sciDisp();
}
function sciDot() {
  if (!sciState.display.includes('.')) { sciState.display += '.'; sciState.newN = false; }
  sciDisp();
}
function sciDel() { sciState.display = sciState.display.length>1?sciState.display.slice(0,-1):'0'; sciDisp(); }
function sciAc() { sciState.expr=''; sciState.display='0'; sciState.newN=true; sciDisp(); }
function sciOp(o) { sciState.expr += sciState.display+' '+o+' '; sciState.newN=true; sciDisp(); }
function sciParOpen() { sciState.expr += '('; sciDisp(); }
function sciParClose() { sciState.expr += sciState.display+')'; sciState.newN=true; sciDisp(); }
function sciConst(c) {
  if (c==='pi') sciState.display = String(Math.PI);
  else if (c==='e') sciState.display = String(Math.E);
  else if (c==='ans') sciState.display = String(sciState.ans);
  sciState.newN=true; sciDisp();
}
function sciFn(fn) {
  const v = parseFloat(sciState.display);
  const toRad = sciState.mode==='deg'?Math.PI/180:1;
  const fromRad = sciState.mode==='deg'?180/Math.PI:1;
  let r;
  switch(fn) {
    case 'sin': r=Math.sin(v*toRad); break;
    case 'cos': r=Math.cos(v*toRad); break;
    case 'tan': r=Math.tan(v*toRad); break;
    case 'asin': r=Math.asin(v)*fromRad; break;
    case 'acos': r=Math.acos(v)*fromRad; break;
    case 'atan': r=Math.atan(v)*fromRad; break;
    case 'log': r=Math.log10(v); break;
    case 'ln': r=Math.log(v); break;
    case 'sqrt': r=Math.sqrt(v); break;
    case 'cbrt': r=Math.cbrt(v); break;
    case 'sq': r=v*v; break;
    case 'cb': r=v*v*v; break;
    case 'inv': r=1/v; break;
    case 'abs': r=Math.abs(v); break;
    case 'pct': r=v/100; break;
    case 'fact':
      if (v<0||!Number.isInteger(v)){r=NaN;break;}
      r=1; for(let i=2;i<=v;i++) r*=i; break;
  }
  sciState.expr=fn+'('+v+') =';
  sciState.display=isNaN(r)?'Error':String(parseFloat(r.toFixed(10)));
  sciState.ans=parseFloat(sciState.display)||0;
  sciState.newN=true; sciDisp();
}
function sciEq() {
  try {
    let expr = sciState.expr+sciState.display;
    expr = expr.replace(/×/g,'*').replace(/÷/g,'/').replace(/−/g,'-').replace(/\^/g,'**');
    const r = Function('"use strict";return('+expr+')')();
    sciState.ans=parseFloat(r.toFixed(10));
    sciState.expr=expr+' =';
    sciState.display=String(parseFloat(r.toFixed(10)));
    sciState.newN=true; sciDisp();
  } catch(e) { sciState.display='Error'; sciDisp(); }
}
</script>