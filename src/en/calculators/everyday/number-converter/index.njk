<script>
function calcNS() {
  const num = document.getElementById('ns-num').value.trim().toUpperCase();
  const base = parseInt(document.getElementById('ns-base').value);
  if (!num) return;
  const decimal = parseInt(num, base);
  if (isNaN(decimal)) {
    document.getElementById('ns-res').textContent = 'Invalid number for the selected base';
    return;
  }
  document.getElementById('ns-res').innerHTML =
    `Decimal: ${decimal}
    <small>
    Binary: ${decimal.toString(2)} · 
    Octal: ${decimal.toString(8)} · 
    Hexadecimal: ${decimal.toString(16).toUpperCase()}
    </small>`;
}
</script>