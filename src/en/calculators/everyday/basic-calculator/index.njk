<script>
let cb = { v:'0', expr:'', op:null, newN:true };
function cbDisp() {
  document.getElementById('calc-val').textContent = cb.v;
  document.getElementById('calc-expr').textContent = cb.expr;
}
function cbNum(d) {
  if (cb.newN) { cb.v = d; cb.newN = false; }
  else cb.v = cb.v === '0' ? d : cb.v + d;
  cbDisp();
}
function cbDot() {
  if (!cb.v.includes('.')) { cb.v += '.'; cb.newN = false; }
  cbDisp();
}
function cbAc() { cb = {v:'0',expr:'',op:null,newN:true}; cbDisp(); }
function cbOp(o) {
  if (o==='+/-') { cb.v = String(-(parseFloat(cb.v)||0)); cbDisp(); return; }
  if (o==='%') { cb.v = String(parseFloat(cb.v)/100); cbDisp(); return; }
  cbEq();
  cb.op = o; cb.expr = cb.v+' '+o; cb.newN = true; cbDisp();
}
function cbEq() {
  if (!cb.op) return;
  const a = parseFloat(cb.expr), b = parseFloat(cb.v);
  const r = cb.op==='+'?a+b:cb.op==='−'?a-b:cb.op==='×'?a*b:b!==0?a/b:'Error';
  cb = {v:typeof r==='number'?String(parseFloat(r.toFixed(10))):r,expr:'',op:null,newN:true};
  cbDisp();
}
document.addEventListener('keydown', e => {
  if ('0123456789'.includes(e.key)) cbNum(e.key);
  else if (e.key==='.') cbDot();
  else if (e.key==='Enter'||e.key==='=') cbEq();
  else if (e.key==='+') cbOp('+');
  else if (e.key==='-') cbOp('−');
  else if (e.key==='*') cbOp('×');
  else if (e.key==='/') { e.preventDefault(); cbOp('÷'); }
  else if (e.key==='Escape') cbAc();
  else if (e.key==='Backspace') { cb.v=cb.v.length>1?cb.v.slice(0,-1):'0'; cbDisp(); }
});
</script>