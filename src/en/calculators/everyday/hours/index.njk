<script>
document.getElementById('hrs-modo').addEventListener('change', toggleHours);

function toggleHours() {
  const m = document.getElementById('hrs-modo').value;
  document.getElementById('hrs-duraciones').style.display = m === 'diferencia' ? 'none' : 'block';
  document.getElementById('hrs-horas').style.display = m === 'diferencia' ? 'block' : 'none';
  document.getElementById('hrs-res').textContent = 'Enter the times';
}

function calcHours() {
  const modo = document.getElementById('hrs-modo').value;
  if (modo === 'diferencia') {
    const ini = document.getElementById('hrs-ini').value;
    const fin = document.getElementById('hrs-fin').value;
    if (!ini || !fin) return;
    const [h1,m1] = ini.split(':').map(Number);
    const [h2,m2] = fin.split(':').map(Number);
    let diff = (h2*60+m2) - (h1*60+m1);
    if (diff < 0) diff += 1440;
    const h = Math.floor(diff/60), m = diff%60;
    document.getElementById('hrs-res').innerHTML =
      `${h}h ${m}min<small>${diff} minutes total</small>`;
  } else {
    const h1 = parseInt(document.getElementById('hrs-h1').value)||0;
    const m1 = parseInt(document.getElementById('hrs-m1').value)||0;
    const h2 = parseInt(document.getElementById('hrs-h2').value)||0;
    const m2 = parseInt(document.getElementById('hrs-m2').value)||0;
    let total = modo==='sumar' ? (h1*60+m1)+(h2*60+m2) : (h1*60+m1)-(h2*60+m2);
    const neg = total < 0;
    total = Math.abs(total);
    const h = Math.floor(total/60), m = total%60;
    document.getElementById('hrs-res').innerHTML =
      `${neg?'−':''}${h}h ${m}min<small>${neg?'−':''}${total} minutes total</small>`;
  }
}
</script>