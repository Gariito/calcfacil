<script>
const FX = { EUR:1, USD:1.08, GBP:0.86, JPY:163, CHF:0.97, CAD:1.47, AUD:1.63, CNY:7.8, MXN:18.5, BRL:5.4 };
function calcCurrency() {
  const v = parseFloat(document.getElementById('cur-val').value);
  const f = document.getElementById('cur-from').value;
  const t = document.getElementById('cur-to').value;
  if (isNaN(v)) return;
  const res = v / FX[f] * FX[t];
  document.getElementById('cur-res').innerHTML =
    `${res.toFixed(2)} ${t}<small>1 ${f} ≈ ${(FX[t]/FX[f]).toFixed(4)} ${t} (approx.)</small>`;
}
</script>