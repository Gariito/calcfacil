<script>
function calcSplit() {
  const total = parseFloat(document.getElementById('split-total').value);
  const pers = parseInt(document.getElementById('split-pers').value);
  const pct = parseInt(document.getElementById('split-pct').value);
  if (!total || !pers) return;
  const tip = total * pct / 100;
  const grand = total + tip;
  const perPerson = grand / pers;

  document.getElementById('split-res').innerHTML =
    `${perPerson.toFixed(2)} per person
    <small>Total with tip: ${grand.toFixed(2)} · Tip: ${tip.toFixed(2)} · ${pers} people</small>`;

  let rows = '';
  for (let i = 1; i <= Math.min(pers, 12); i++) {
    rows += `<div style="display:flex;justify-content:space-between;padding:0.4rem 0;border-bottom:1px solid var(--border);font-size:0.875rem">
      <span>Person ${i}</span>
      <span style="font-weight:600">${perPerson.toFixed(2)}</span>
    </div>`;
  }
  if (pers > 12) rows += `<div style="font-size:0.8rem;color:var(--muted);margin-top:0.5rem">... and ${pers-12} more × ${perPerson.toFixed(2)}</div>`;

  document.getElementById('split-desglose').innerHTML =
    `<p style="font-size:0.875rem;font-weight:600;margin-bottom:0.5rem">Breakdown per person</p>${rows}`;
}
</script>