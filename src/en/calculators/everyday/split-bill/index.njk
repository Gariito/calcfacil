        <h1>🍽️ Bill Splitter</h1>
        <p class="calc-intro">Split any restaurant bill equally between multiple people, including tip.</p>

        <div class="card">
          <label>Total bill amount</label>
          <input type="number" id="split-total" placeholder="120.50" oninput="calcSplit()">

          <label>Number of people</label>
          <input type="number" id="split-pers" placeholder="4" oninput="calcSplit()">

          <label>Tip percentage</label>
          <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1rem">
            <input type="range" min="0" max="30" value="15" id="split-pct"
              oninput="document.getElementById('split-pct-val').textContent=this.value+'%'; calcSplit()"
              style="flex:1;margin-bottom:0">
            <span id="split-pct-val" style="font-weight:600;min-width:40px">15%</span>
