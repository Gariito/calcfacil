<script>
document.addEventListener('DOMContentLoaded', () => {
  const today = new Date().toISOString().split('T')[0];
  document.getElementById('dd-start').value = today;
});

function setDatePreset(days) {
  const today = new Date();
  const future = new Date(today.getTime() + days * 86400000);
  document.getElementById('dd-start').value = today.toISOString().split('T')[0];
  document.getElementById('dd-end').value = future.toISOString().split('T')[0];
  calcDD();
}

function calcDD() {
  const start = document.getElementById('dd-start').value;
  const end = document.getElementById('dd-end').value;
  const work = document.getElementById('dd-work').value;
  if (!start || !end) return;
  const d1 = new Date(start), d2 = new Date(end);
  const diff = Math.round((d2 - d1) / 86400000);
  if (diff < 0) { document.getElementById('dd-res').textContent = 'End date is before start date'; return; }
  let workDays = 0;
  if (work === 'yes') {
    let cur = new Date(d1);
    while (cur < d2) {
      const dow = cur.getDay();
      if (dow !== 0 && dow !== 6) workDays++;
      cur.setDate(cur.getDate() + 1);
    }
  }
  const weeks = Math.floor(diff / 7);
  const rem = diff % 7;
  const months = Math.floor(diff / 30.44);
  document.getElementById('dd-res').innerHTML =
    `${diff} days
    <small>${weeks} week${weeks!==1?'s':''} and ${rem} day${rem!==1?'s':''} · ~${months} month${months!==1?'s':''}${work==='yes'?' · '+workDays+' working days':''}</small>`;
}
</script>