        <h1>📅 Date Difference Calculator</h1>
        <p class="calc-intro">Calculate the exact number of days, weeks and months between any two dates.</p>

        <div class="card">
          <div class="row-2">
            <div>
              <label>Start date</label>
              <input type="date" id="dd-start" oninput="calcDD()" style="width:100%;padding:0.65rem 0.9rem;border:1px solid var(--border);border-radius:8px;font-size:1rem;background:var(--bg);margin-bottom:1rem">
            </div>
            <div>
              <label>End date</label>
              <input type="date" id="dd-end" oninput="calcDD()" style="width:100%;padding:0.65rem 0.9rem;border:1px solid var(--border);border-radius:8px;font-size:1rem;background:var(--bg);margin-bottom:1rem">
            </div>
          </div>

          <label>Count only working days?</label>
          <select id="dd-work" onchange="calcDD()">
            <option value="no">No — count all days</option>
            <option value="yes">Yes — working days only (Mon–Fri)</option>
          </select>

          <div class="result-box" id="dd-res">Enter the two dates</div>
        </div>

        <div style="margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--border)">
          <h2 style="font-family:var(--font-display);font-size:1.2rem;font-weight:700;margin-bottom:1rem">Common date calculations</h2>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;font-size:0.85rem">
            <button onclick="setDatePreset(30)" style="padding:0.5rem;border:1px solid var(--border);border-radius:8px;background:var(--bg);cursor:pointer;text-align:left">📅 Days in 30 days</button>
            <button onclick="setDatePreset(90)" style="padding:0.5rem;border:1px solid var(--border);border-radius:8px;background:var(--bg);cursor:pointer;text-align:left">📅 Days in 90 days</button>
            <button onclick="setDatePreset(180)" style="padding:0.5rem;border:1px solid var(--border);border-radius:8px;background:var(--bg);cursor:pointer;text-align:left">📅 Days in 6 months</button>
            <button onclick="setDatePreset(365)" style="padding:0.5rem;border:1px solid var(--border);border-radius:8px;background:var(--bg);cursor:pointer;text-align:left">📅 Days in 1 year</button>
