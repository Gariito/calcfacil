<script>
const romVals = [[1000,'M'],[900,'CM'],[500,'D'],[400,'CD'],[100,'C'],[90,'XC'],
  [50,'L'],[40,'XL'],[10,'X'],[9,'IX'],[5,'V'],[4,'IV'],[1,'I']];
function toRoman(n) { let r=''; for(const [v,s] of romVals){while(n>=v){r+=s;n-=v;}} return r; }
function fromRoman(s) {
  const map={I:1,V:5,X:10,L:50,C:100,D:500,M:1000};
  let r=0;
  for(let i=0;i<s.length;i++){const cur=map[s[i]],nxt=map[s[i+1]];if(!cur)return NaN;r+=nxt>cur?-cur:cur;}
  return r;
}
function toggleRom() {
  const m=document.getElementById('rom-modo').value;
  document.getElementById('rom-dec').style.display=m==='dr'?'block':'none';
  document.getElementById('rom-rom').style.display=m==='rd'?'block':'none';
  document.getElementById('rom-res').textContent='Enter a number';
}
function calcRom() {
  const m=document.getElementById('rom-modo').value;
  if(m==='dr'){
    const n=parseInt(document.getElementById('rom-num').value);
    if(!n||n<1||n>3999){document.getElementById('rom-res').textContent='Enter a number between 1 and 3999';return;}
    document.getElementById('rom-res').innerHTML=`${toRoman(n)}<small>${n} in Roman numerals</small>`;
  } else {
    const s=document.getElementById('rom-txt').value.toUpperCase().trim();
    if(!s)return;
    const n=fromRoman(s);
    if(isNaN(n)||n<=0){document.getElementById('rom-res').textContent='Invalid Roman numeral';return;}
    document.getElementById('rom-res').innerHTML=`${n}<small>${s} in decimal</small>`;
  }
}
</script>