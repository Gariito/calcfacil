<script>
function toggleDiscType() {
  const tipo = document.getElementById('disc-tipo').value;
  document.getElementById('disc-val-label').textContent = tipo === 'pct' ? 'Discount (%)' : 'Discount amount';
  calcDisc();
}
function setDisc(v) {
  document.getElementById('disc-tipo').value = 'pct';
  document.getElementById('disc-val-label').textContent = 'Discount (%)';
  document.getElementById('disc-val').value = v;
  calcDisc();
}
function calcDisc() {
  const price = parseFloat(document.getElementById('disc-price').value);
  const tipo = document.getElementById('disc-tipo').value;
  const val = parseFloat(document.getElementById('disc-val').value);
  if (!price || !val) return;
  let savings, final, pct;
  if (tipo === 'pct') {
    savings = price * val / 100;
    final = price - savings;
    pct = val;
  } else {
    savings = val;
    final = price - val;
    pct = (val / price * 100).toFixed(1);
  }
  document.getElementById('disc-res').innerHTML =
    `Sale price: ${final.toFixed(2)}<small>You save: ${savings.toFixed(2)} (${pct}% off) · Original: ${price.toFixed(2)}</small>`;
}
</script>