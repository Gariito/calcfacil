<script>
function calcIMC() {
  const peso = parseFloat(document.getElementById('imc-peso').value);
  const altura = parseFloat(document.getElementById('imc-altura').value);
  if (!peso || !altura) return;
  const h = altura / 100;
  const imc = peso / (h * h);
  let cat, color;
  if (imc < 18.5) { cat = 'Underweight'; color = '#3B82F6'; }
  else if (imc < 25) { cat = 'Normal weight ✓'; color = '#22C55E'; }
  else if (imc < 30) { cat = 'Overweight'; color = '#EAB308'; }
  else { cat = 'Obese'; color = '#EF4444'; }
  document.getElementById('imc-res').innerHTML =
    `<span style="color:${color}">BMI: ${imc.toFixed(1)} — ${cat}</span>`;
  const pct = Math.min(Math.max((imc - 10) / 40 * 100, 0), 100);
  document.getElementById('imc-marker').style.left = pct + '%';
}
</script>