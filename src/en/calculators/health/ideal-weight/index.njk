<script>
function calcIdealWeight() {
  const h = parseFloat(document.getElementById('pi-altura').value);
  const sexo = document.getElementById('pi-sexo').value;
  if (!h) return;
  const hm = h / 100;
  const hIn = (h - 152.4) / 2.54;
  const lorentz = sexo==='h' ? h-100-(h-150)/4 : h-100-(h-150)/2;
  const devine = sexo==='h' ? 50+2.3*hIn : 45.5+2.3*hIn;
  const hamwi = sexo==='h' ? 48+2.7*hIn : 45.4+2.2*hIn;
  const bmiMin = (18.5*hm*hm).toFixed(1);
  const bmiMax = (24.9*hm*hm).toFixed(1);
  document.getElementById('pi-res').innerHTML =
    `Healthy range: ${bmiMin} – ${bmiMax} kg
    <small>Lorentz: ${lorentz.toFixed(1)} kg · Devine: ${devine.toFixed(1)} kg · Hamwi: ${hamwi.toFixed(1)} kg</small>`;
}
</script>