</div>

<script>
function calcPaint() {
  const a = parseFloat(document.getElementById('pin-ancho').value);
  const l = parseFloat(document.getElementById('pin-largo').value);
  const h = parseFloat(document.getElementById('pin-alto').value);
  const puertas = (parseFloat(document.getElementById('pin-puertas').value)||0)*1.85;
  const ventanas = (parseFloat(document.getElementById('pin-ventanas').value)||0)*1.2;
  const manos = parseFloat(document.getElementById('pin-manos').value)||2;
  const rend = parseFloat(document.getElementById('pin-rend').value)||10;
  if (!a||!l||!h) return;
  const superfParedes = 2*(a+l)*h;
  const superfNeta = superfParedes-puertas-ventanas;
  const litros = (superfNeta*manos)/rend;
  document.getElementById('pin-res').innerHTML =
    `${litros.toFixed(1)} litres<small>Wall area: ${superfNeta.toFixed(1)} m² · With 10% extra: ${(litros*1.1).toFixed(1)} L</small>`;
}
</script>