<script>
function searchMain(q) {
  const term = q.toLowerCase().trim();
  const cards = document.querySelectorAll('#main-grid .category-card');
  const empty = document.getElementById('main-empty');
  const count = document.getElementById('main-count');
  let visible = 0;

  cards.forEach(card => {
    const searchData = (card.dataset.search || '').toLowerCase();
    const title = (card.querySelector('h2')?.textContent || '').toLowerCase();
    const searchText = searchData + ' ' + title;

    if (!term || searchText.includes(term)) {
      card.classList.remove('hidden');
      visible++;
    } else {
      card.classList.add('hidden');
    }
  });

  if (term) {
    count.textContent = visible + ' categoría' + (visible !== 1 ? 's' : '') + ' encontrada' + (visible !== 1 ? 's' : '');
    document.getElementById('main-empty-term').textContent = q;
    empty.style.display = visible === 0 ? 'block' : 'none';
  } else {
    count.textContent = '';
    empty.style.display = 'none';
  }
}

document.addEventListener('keydown', e => {
  if (e.key === '/' && document.activeElement.tagName !== 'INPUT') {
    e.preventDefault();
    document.getElementById('main-search').focus();
  }
});
</script>