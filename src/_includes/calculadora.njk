---
layout: base.njk
---
<div class="calc-page">
  <div class="container calc-container">

    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Ruta">
      <a href="/">Inicio</a>
      <span>›</span>
      <a href="/calculadoras/{{ categoria }}/">{{ categoriaLabel }}</a>
      <span>›</span>
      <span>{{ titulo }}</span>
    </nav>

    <div class="calc-layout">

      <!-- Calculadora principal -->
      <div class="calc-main">
        <h1>{{ icono }} {{ titulo }}</h1>
        <p class="calc-intro">{{ descripcion }}</p>
        <div class="card">
          {{ content | safe }}
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="calc-sidebar">
        <div class="card sidebar-card">
          <h2>¿Qué es {{ tituloCorto or titulo }}?</h2>
          <p>{{ explicacion }}</p>
        </div>

        {% if relacionadas %}
        <div class="card sidebar-card">
          <h3>Calculadoras relacionadas</h3>
          <ul class="related-list">
            {% for rel in relacionadas %}
            <li><a href="/calculadoras/{{ rel.categoria }}/{{ rel.slug }}/">{{ rel.icono }} {{ rel.titulo }}</a></li>
            {% endfor %}
          </ul>
        </div>
        {% endif %}

        <div class="card sidebar-card faq-card">
          <h3>Preguntas frecuentes</h3>
          {% if faq %}
            {% for item in faq %}
            <details>
              <summary>{{ item.q }}</summary>
              <p>{{ item.a }}</p>
            </details>
            {% endfor %}
          {% endif %}
        </div>
      </aside>

    </div>
  </div>
</div>